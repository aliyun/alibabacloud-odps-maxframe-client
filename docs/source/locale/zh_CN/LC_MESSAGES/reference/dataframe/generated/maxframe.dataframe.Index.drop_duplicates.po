#: ../../source/reference/dataframe/generated/maxframe.dataframe.Index.drop_duplicates.rst:2
msgid "maxframe.dataframe.Index.drop\\_duplicates"
msgstr ""

#: maxframe.dataframe.misc.drop_duplicates.index_drop_duplicates:1 of
msgid "Return Index with duplicate values removed."
msgstr "返回去除重复值后的 Index。"

#: maxframe.dataframe.misc.drop_duplicates.index_drop_duplicates of
msgid "参数"
msgstr ""

#: maxframe.dataframe.misc.drop_duplicates.index_drop_duplicates:3 of
msgid ""
"- 'first' : Drop duplicates except for the first occurrence. - 'last' : "
"Drop duplicates except for the last occurrence. - 'any' : Drop duplicates"
" except for a random occurrence. - ``False`` : Drop all duplicates."
msgstr ""
"- 'first' : 保留第一次出现的值，删除其余重复项。 - 'last' : 保留最后一次"
"出现的值，删除其余重复项。 - 'any' : 保留任意一次出现的值，删除其余重复项"
"。 - ``False`` : 删除所有重复项。"

#: maxframe.dataframe.misc.drop_duplicates.index_drop_duplicates:4 of
msgid "'first' : Drop duplicates except for the first occurrence."
msgstr "'first' : 保留第一次出现的值，删除其余重复项。"

#: maxframe.dataframe.misc.drop_duplicates.index_drop_duplicates:5 of
msgid "'last' : Drop duplicates except for the last occurrence."
msgstr "'last' : 保留最后一次出现的值，删除其余重复项。"

#: maxframe.dataframe.misc.drop_duplicates.index_drop_duplicates:6 of
msgid "'any' : Drop duplicates except for a random occurrence."
msgstr "'any' : 保留任意一次出现的值，删除其余重复项。"

#: maxframe.dataframe.misc.drop_duplicates.index_drop_duplicates:7 of
msgid "``False`` : Drop all duplicates."
msgstr "``False`` : 删除所有重复项。"

#: maxframe.dataframe.misc.drop_duplicates.index_drop_duplicates of
msgid "返回"
msgstr ""

#: maxframe.dataframe.misc.drop_duplicates.index_drop_duplicates:10 of
msgid "**deduplicated**"
msgstr ""

#: maxframe.dataframe.misc.drop_duplicates.index_drop_duplicates of
msgid "返回类型"
msgstr ""

#: maxframe.dataframe.misc.drop_duplicates.index_drop_duplicates:15 of
msgid ":py:obj:`Series.drop_duplicates`"
msgstr ""

#: maxframe.dataframe.misc.drop_duplicates.index_drop_duplicates:16 of
msgid "Equivalent method on Series."
msgstr "Series 上的等效方法。"

#: maxframe.dataframe.misc.drop_duplicates.index_drop_duplicates:18 of
msgid ":py:obj:`DataFrame.drop_duplicates`"
msgstr ""

#: maxframe.dataframe.misc.drop_duplicates.index_drop_duplicates:19 of
msgid "Equivalent method on DataFrame."
msgstr "DataFrame 上的等效方法。"

#: maxframe.dataframe.misc.drop_duplicates.index_drop_duplicates:21 of
msgid ":py:obj:`Index.duplicated`"
msgstr ""

#: maxframe.dataframe.misc.drop_duplicates.index_drop_duplicates:22 of
msgid "Related method on Index, indicating duplicate Index values."
msgstr "Index 上的相关方法，用于指示重复的 Index 值。"

#: maxframe.dataframe.misc.drop_duplicates.index_drop_duplicates:25 of
msgid "示例"
msgstr ""

#: maxframe.dataframe.misc.drop_duplicates.index_drop_duplicates:26 of
msgid "Generate a pandas.Index with duplicate values."
msgstr "生成一个包含重复值的 pandas.Index。"

#: maxframe.dataframe.misc.drop_duplicates.index_drop_duplicates:32 of
msgid ""
"The `keep` parameter controls  which duplicate values are removed. The "
"value 'first' keeps the first occurrence for each set of duplicated "
"entries. The default value of keep is 'first'."
msgstr ""
"`keep` 参数控制删除哪些重复值。'first' 值会保留每组重复项中的第一次出现的"
"值。keep 的默认值是 'first'。"

#: maxframe.dataframe.misc.drop_duplicates.index_drop_duplicates:39 of
msgid ""
"The value 'last' keeps the last occurrence for each set of duplicated "
"entries."
msgstr "'last' 值会保留每组重复项中的最后一次出现的值。"

#: maxframe.dataframe.misc.drop_duplicates.index_drop_duplicates:45 of
msgid "The value ``False`` discards all sets of duplicated entries."
msgstr "``False`` 值会丢弃所有重复项。"

