msgid "maxframe.dataframe.Index.argmin"
msgstr ""

#: maxframe.dataframe.reduction.argmin.argmin_series_index:1 of
msgid "Return int position of the smallest value in the Series."
msgstr "返回 Series 中最小值的整数位置。"

#: maxframe.dataframe.reduction.argmin.argmin_series_index:3 of
msgid ""
"If the minimum is achieved in multiple locations, the first row position "
"is returned."
msgstr "如果最小值在多个位置达到，则返回第一个行位置。"

#: maxframe.dataframe.reduction.argmin.argmin_series_index of
msgid "参数"
msgstr ""

#: maxframe.dataframe.reduction.argmin.argmin_series_index:6 of
msgid "Unused. Parameter needed for compatibility with DataFrame."
msgstr "未使用。该参数是为了与 DataFrame 兼容而需要的。"

#: maxframe.dataframe.reduction.argmin.argmin_series_index:8 of
msgid "Exclude NA/null values when showing the result."
msgstr "显示结果时排除 NA/null 值。"

#: maxframe.dataframe.reduction.argmin.argmin_series_index:10
#: maxframe.dataframe.reduction.argmin.argmin_series_index:11 of
msgid "Additional arguments and keywords for compatibility with NumPy."
msgstr "为与 NumPy 兼容而提供的额外参数和关键字。"

#: maxframe.dataframe.reduction.argmin.argmin_series_index of
msgid "返回"
msgstr ""

#: maxframe.dataframe.reduction.argmin.argmin_series_index:13 of
msgid "Row position of the minimum value."
msgstr "最小值的行位置。"

#: maxframe.dataframe.reduction.argmin.argmin_series_index of
msgid "返回类型"
msgstr ""

#: maxframe.dataframe.reduction.argmin.argmin_series_index:18 of
msgid ":py:obj:`Series.argmin`"
msgstr ""

#: maxframe.dataframe.reduction.argmin.argmin_series_index:19 of
msgid "Return position of the minimum value."
msgstr "返回最小值的位置。"

#: maxframe.dataframe.reduction.argmin.argmin_series_index:21 of
msgid ":py:obj:`Series.argmax`"
msgstr ""

#: maxframe.dataframe.reduction.argmin.argmin_series_index:22 of
msgid "Return position of the maximum value."
msgstr "返回最大值的位置。"

#: maxframe.dataframe.reduction.argmin.argmin_series_index:24 of
msgid ":py:obj:`maxframe.tensor.argmin`"
msgstr ""

#: maxframe.dataframe.reduction.argmin.argmin_series_index:25 of
msgid "Equivalent method for tensors."
msgstr "等效的张量方法。"

#: maxframe.dataframe.reduction.argmin.argmin_series_index:27 of
msgid ":py:obj:`Series.idxmax`"
msgstr ""

#: maxframe.dataframe.reduction.argmin.argmin_series_index:28 of
msgid "Return index label of the maximum values."
msgstr "返回最大值的索引标签。"

#: maxframe.dataframe.reduction.argmin.argmin_series_index:30 of
msgid ":py:obj:`Series.idxmin`"
msgstr ""

#: maxframe.dataframe.reduction.argmin.argmin_series_index:31 of
msgid "Return index label of the minimum values."
msgstr "返回最小值的索引标签。"

#: maxframe.dataframe.reduction.argmin.argmin_series_index:34 of
msgid "示例"
msgstr ""

#: maxframe.dataframe.reduction.argmin.argmin_series_index:35 of
msgid "Consider dataset containing cereal calories"
msgstr "考虑包含谷物热量的数据集"

#: maxframe.dataframe.reduction.argmin.argmin_series_index:52 of
msgid ""
"The maximum cereal calories is the third element and the minimum cereal "
"calories is the first element, since series is zero-indexed."
msgstr ""
"由于 Series 是从零开始索引的，最大谷物热量是第三个元素，最小谷物热量是"
"第一个元素。"

