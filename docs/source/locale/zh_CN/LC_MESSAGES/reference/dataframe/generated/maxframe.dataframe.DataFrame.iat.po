#: ../../source/reference/dataframe/generated/maxframe.dataframe.DataFrame.iat.rst:2
msgid "maxframe.dataframe.DataFrame.iat"
msgstr ""

#: maxframe.dataframe.DataFrame.iat:1 of
msgid "Access a single value for a row/column pair by integer position."
msgstr "通过整数位置访问行/列对的单个值。"

#: maxframe.dataframe.DataFrame.iat:3 of
msgid ""
"Similar to ``iloc``, in that both provide integer-based lookups. Use "
"``iat`` if you only need to get or set a single value in a DataFrame or "
"Series."
msgstr ""
"类似于 ``iloc``，两者都提供基于整数的查找。如果只需要获取或设置 DataFrame"
" 或 Series 中的单个值，请使用 ``iat``。"

#: maxframe.dataframe.DataFrame.iat of
msgid "抛出"
msgstr ""

#: maxframe.dataframe.DataFrame.iat:7 of
msgid "When integer position is out of bounds."
msgstr "当整数位置越界时。"

#: maxframe.dataframe.DataFrame.iat:11 of
msgid ":py:obj:`DataFrame.at`"
msgstr ""

#: maxframe.dataframe.DataFrame.iat:12 of
msgid "Access a single value for a row/column label pair."
msgstr "访问行/列标签对的单个值。"

#: maxframe.dataframe.DataFrame.iat:14 of
msgid ":py:obj:`DataFrame.loc`"
msgstr ""

#: maxframe.dataframe.DataFrame.iat:15 of
msgid "Access a group of rows and columns by label(s)."
msgstr "通过标签访问一组行和列。"

#: maxframe.dataframe.DataFrame.iat:17 of
msgid ":py:obj:`DataFrame.iloc`"
msgstr ""

#: maxframe.dataframe.DataFrame.iat:18 of
msgid "Access a group of rows and columns by integer position(s)."
msgstr "通过整数位置访问一组行和列。"

#: maxframe.dataframe.DataFrame.iat:21 of
msgid "示例"
msgstr ""

#: maxframe.dataframe.DataFrame.iat:31 of
msgid "Get value at specified row/column pair"
msgstr "获取指定行/列对的值"

#: maxframe.dataframe.DataFrame.iat:36 of
msgid "Set value at specified row/column pair"
msgstr "设置指定行/列对的值"

#: maxframe.dataframe.DataFrame.iat:42 of
msgid "Get value within a series"
msgstr "获取 Series 中的值"

