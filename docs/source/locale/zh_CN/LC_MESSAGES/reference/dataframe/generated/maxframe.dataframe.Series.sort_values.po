#: ../../source/reference/dataframe/generated/maxframe.dataframe.Series.sort_values.rst:2
msgid "maxframe.dataframe.Series.sort\\_values"
msgstr ""

#: maxframe.dataframe.sort.sort_values.series_sort_values:1 of
msgid "Sort by the values."
msgstr "按值排序。"

#: maxframe.dataframe.sort.sort_values.series_sort_values:3 of
msgid "Sort a Series in ascending or descending order by some criterion."
msgstr "根据某个标准按升序或降序对 Series 进行排序。"

#: maxframe.dataframe.sort.sort_values.series_sort_values of
msgid "参数"
msgstr ""

#: maxframe.dataframe.sort.sort_values.series_sort_values:8 of
msgid ""
"Axis to direct sorting. The value 'index' is accepted for compatibility "
"with DataFrame.sort_values."
msgstr "用于指定排序的轴。为与 DataFrame.sort_values 兼容，接受值 'index'。"

#: maxframe.dataframe.sort.sort_values.series_sort_values:11 of
msgid "If True, sort values in ascending order, otherwise descending."
msgstr "如果为 True，则按升序排序值，否则按降序排序。"

#: maxframe.dataframe.sort.sort_values.series_sort_values:13 of
msgid "If True, perform operation in-place."
msgstr "如果为 True，则就地执行操作。"

#: maxframe.dataframe.sort.sort_values.series_sort_values:15 of
msgid ""
"Choice of sorting algorithm. See also :func:`numpy.sort` for more "
"information. 'mergesort' is the only stable  algorithm."
msgstr ""
"选择排序算法。更多信息请参见 :func:`numpy.sort`。'mergesort' 是唯一稳定的"
"算法。"

#: maxframe.dataframe.sort.sort_values.series_sort_values:18 of
msgid "Argument 'first' puts NaNs at the beginning, 'last' puts NaNs at the end."
msgstr "参数 'first' 将 NaN 放在开头，'last' 将 NaN 放在末尾。"

#: maxframe.dataframe.sort.sort_values.series_sort_values:21 of
msgid "If True, the resulting axis will be labeled 0, 1, …, n - 1."
msgstr "如果为 True，则结果轴将被标记为 0, 1, …, n - 1。"

#: maxframe.dataframe.sort.sort_values.series_sort_values of
msgid "返回"
msgstr ""

#: maxframe.dataframe.sort.sort_values.series_sort_values:24 of
msgid "Series ordered by values."
msgstr "按值排序后的 Series。"

#: maxframe.dataframe.sort.sort_values.series_sort_values of
msgid "返回类型"
msgstr ""

#: maxframe.dataframe.sort.sort_values.series_sort_values:28 of
msgid "示例"
msgstr ""

#: maxframe.dataframe.sort.sort_values.series_sort_values:40 of
msgid "Sort values ascending order (default behaviour)"
msgstr "按升序排序值（默认行为）"

#: maxframe.dataframe.sort.sort_values.series_sort_values:50 of
msgid "Sort values descending order"
msgstr "按降序排序值"

#: maxframe.dataframe.sort.sort_values.series_sort_values:60 of
msgid "Sort values inplace"
msgstr "就地排序值"

#: maxframe.dataframe.sort.sort_values.series_sort_values:71 of
msgid "Sort values putting NAs first"
msgstr "排序值并将 NA 放在最前"

