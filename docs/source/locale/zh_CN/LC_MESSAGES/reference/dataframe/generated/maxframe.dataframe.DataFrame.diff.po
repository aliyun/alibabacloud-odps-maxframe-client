#: ../../source/reference/dataframe/generated/maxframe.dataframe.DataFrame.diff.rst:2
msgid "maxframe.dataframe.DataFrame.diff"
msgstr ""

#: maxframe.dataframe.misc.diff.df_diff:1 of
msgid ""
"First discrete difference of element. Calculates the difference of a "
"DataFrame element compared with another element in the DataFrame (default"
" is the element in the same column of the previous row)."
msgstr ""
"元素的一阶差分。计算 DataFrame 中某个元素与 DataFrame 中另一个元素的差值"
"（默认为前一行同一列的元素）。"

#: maxframe.dataframe.misc.diff.df_diff of
msgid "参数"
msgstr ""

#: maxframe.dataframe.misc.diff.df_diff:6 of
msgid "Periods to shift for calculating difference, accepts negative values."
msgstr "用于计算差值的偏移周期数，可接受负值。"

#: maxframe.dataframe.misc.diff.df_diff:9 of
msgid "Take difference over rows (0) or columns (1)."
msgstr "在行（0）或列（1）上进行差分计算。"

#: maxframe.dataframe.misc.diff.df_diff of
msgid "返回类型"
msgstr ""

#: maxframe.dataframe.misc.diff.df_diff:16 of
msgid ":py:obj:`Series.diff`"
msgstr ""

#: maxframe.dataframe.misc.diff.df_diff:17 of
msgid "First discrete difference for a Series."
msgstr "Series 的一阶差分。"

#: maxframe.dataframe.misc.diff.df_diff:19 of
msgid ":py:obj:`DataFrame.pct_change`"
msgstr ""

#: maxframe.dataframe.misc.diff.df_diff:20 of
msgid "Percent change over given number of periods."
msgstr "在给定周期数上的百分比变化。"

#: maxframe.dataframe.misc.diff.df_diff:22 of
msgid ":py:obj:`DataFrame.shift`"
msgstr ""

#: maxframe.dataframe.misc.diff.df_diff:23 of
msgid "Shift index by desired number of periods with an optional time freq."
msgstr "根据指定的周期数（可选时间频率）移动索引。"

#: maxframe.dataframe.misc.diff.df_diff:26 of
msgid "备注"
msgstr ""

#: maxframe.dataframe.misc.diff.df_diff:27 of
msgid ""
"For boolean dtypes, this uses :meth:`operator.xor` rather than "
":meth:`operator.sub`."
msgstr ""
"对于布尔类型的数据，使用 :meth:`operator.xor` 而不是 :meth:`operator.sub`"
"。"

#: maxframe.dataframe.misc.diff.df_diff:31 of
msgid "示例"
msgstr ""

#: maxframe.dataframe.misc.diff.df_diff:32 of
msgid "Difference with previous row"
msgstr "与前一行的差值"

#: maxframe.dataframe.misc.diff.df_diff:56 of
msgid "Difference with previous column"
msgstr "与前一列的差值"

#: maxframe.dataframe.misc.diff.df_diff:67 of
msgid "Difference with 3rd previous row"
msgstr "与第前三行的差值"

#: maxframe.dataframe.misc.diff.df_diff:78 of
msgid "Difference with following row"
msgstr "与后一行的差值"

