#: ../../source/reference/dataframe/generated/maxframe.dataframe.Index.to_series.rst:2
msgid "maxframe.dataframe.Index.to\\_series"
msgstr ""

#: maxframe.dataframe.core.Index.to_series:1 of
msgid "Create a Series with both index and values equal to the index keys."
msgstr "创建一个 Series，其索引和值都等于索引键。"

#: maxframe.dataframe.core.Index.to_series:3 of
msgid "Useful with map for returning an indexer based on an index."
msgstr "与 map 结合使用，可根据索引返回一个索引器。"

#: ../../source/reference/dataframe/generated/maxframe.dataframe.Index.to_series.rst
msgid "参数"
msgstr ""

#: maxframe.dataframe.core.Index.to_series:5 of
msgid "Index of resulting Series. If None, defaults to original index."
msgstr "结果 Series 的索引。如果为 None，则默认使用原始索引。"

#: maxframe.dataframe.core.Index.to_series:7 of
msgid "Dame of resulting Series. If None, defaults to name of original index."
msgstr "结果 Series 的名称。如果为 None，则默认使用原始索引的名称。"

#: ../../source/reference/dataframe/generated/maxframe.dataframe.Index.to_series.rst
msgid "返回"
msgstr ""

#: maxframe.dataframe.core.Index.to_series:11 of
msgid "The dtype will be based on the type of the Index values."
msgstr "dtype 将基于 Index 值的类型。"

#: ../../source/reference/dataframe/generated/maxframe.dataframe.Index.to_series.rst
msgid "返回类型"
msgstr ""

