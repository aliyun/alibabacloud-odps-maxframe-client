#: ../../source/reference/dataframe/generated/maxframe.dataframe.Series.dt.to_pydatetime.rst:2
msgid "maxframe.dataframe.Series.dt.to_pydatetime"
msgstr ""

#: of pandas.core.indexes.accessors.DatetimeProperties.to_pydatetime:1
msgid "Return the data as an array of :class:`datetime.datetime` objects."
msgstr "将数据作为 :class:`datetime.datetime` 对象的数组返回。"

#: of pandas.core.indexes.accessors.DatetimeProperties.to_pydatetime:5
msgid ""
"The current behavior of dt.to_pydatetime is deprecated. In a future "
"version this will return a Series containing python datetime objects "
"instead of a ndarray."
msgstr ""
"当前 dt.to_pydatetime 的行为已被弃用。在未来的版本中，这将返回一个包含 "
"python datetime 对象的 Series，而不是一个 ndarray。"

#: of pandas.core.indexes.accessors.DatetimeProperties.to_pydatetime:9
msgid "Timezone information is retained if present."
msgstr "如果存在时区信息，则保留。"

#: of pandas.core.indexes.accessors.DatetimeProperties.to_pydatetime:13
msgid ""
"Python's datetime uses microsecond resolution, which is lower than pandas"
" (nanosecond). The values are truncated."
msgstr "Python 的 datetime 使用微秒分辨率，低于 pandas（纳秒）。值将被截断。"

#: of pandas.core.indexes.accessors.DatetimeProperties.to_pydatetime
msgid "返回"
msgstr ""

#: of pandas.core.indexes.accessors.DatetimeProperties.to_pydatetime:16
msgid "Object dtype array containing native Python datetime objects."
msgstr "包含原生 Python datetime 对象的 object 类型数组。"

#: of pandas.core.indexes.accessors.DatetimeProperties.to_pydatetime
msgid "返回类型"
msgstr ""

#: of pandas.core.indexes.accessors.DatetimeProperties.to_pydatetime:21
msgid ":py:obj:`datetime.datetime`"
msgstr ""

#: of pandas.core.indexes.accessors.DatetimeProperties.to_pydatetime:22
msgid "Standard library value for a datetime."
msgstr "datetime 的标准库值。"

#: of pandas.core.indexes.accessors.DatetimeProperties.to_pydatetime:25
msgid "示例"
msgstr ""

#: of pandas.core.indexes.accessors.DatetimeProperties.to_pydatetime:37
msgid "pandas' nanosecond precision is truncated to microseconds."
msgstr "pandas 的纳秒精度将被截断为微秒。"

