#: ../../source/reference/dataframe/generated/maxframe.dataframe.Index.repeat.rst:2
msgid "maxframe.dataframe.Index.repeat"
msgstr ""

#: maxframe.dataframe.misc.repeat.index_repeat:1 of
msgid "Repeat elements of an Index."
msgstr "重复 Index 的元素。"

#: maxframe.dataframe.misc.repeat.index_repeat:3 of
msgid ""
"Returns a new Index where each element of the current Index is repeated "
"consecutively a given number of times."
msgstr "返回一个新的 Index，其中当前 Index 的每个元素都按给定次数连续重复。"

#: maxframe.dataframe.misc.repeat.index_repeat of
msgid "参数"
msgstr ""

#: maxframe.dataframe.misc.repeat.index_repeat:6 of
msgid ""
"The number of repetitions for each element. This should be a non-negative"
" integer. Repeating 0 times will return an empty Index."
msgstr "每个元素的重复次数。这应该是一个非负整数。重复 0 次将返回一个空 Index。"

#: maxframe.dataframe.misc.repeat.index_repeat:10 of
msgid ""
"Must be ``None``. Has no effect but is accepted for compatibility with "
"numpy."
msgstr "必须为 ``None``。此参数无效果，但为了与 numpy 兼容而被接受。"

#: maxframe.dataframe.misc.repeat.index_repeat of
msgid "返回"
msgstr ""

#: maxframe.dataframe.misc.repeat.index_repeat:14 of
msgid "**repeated_index** -- Newly created Index with repeated elements."
msgstr "**repeated_index** -- 新创建的包含重复元素的 Index。"

#: maxframe.dataframe.misc.repeat.index_repeat of
msgid "返回类型"
msgstr ""

#: maxframe.dataframe.misc.repeat.index_repeat:19 of
msgid ":py:obj:`Series.repeat`"
msgstr ""

#: maxframe.dataframe.misc.repeat.index_repeat:20 of
msgid "Equivalent function for Series."
msgstr "Series 的等效函数。"

#: maxframe.dataframe.misc.repeat.index_repeat:22 of
msgid ":py:obj:`numpy.repeat`"
msgstr ""

#: maxframe.dataframe.misc.repeat.index_repeat:23 of
msgid "Similar method for :class:`numpy.ndarray`."
msgstr ":class:`numpy.ndarray` 的类似方法。"

