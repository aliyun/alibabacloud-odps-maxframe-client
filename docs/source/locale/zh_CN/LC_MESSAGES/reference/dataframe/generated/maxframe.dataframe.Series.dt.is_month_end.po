#: ../../source/reference/dataframe/generated/maxframe.dataframe.Series.dt.is_month_end.rst:2
msgid "maxframe.dataframe.Series.dt.is_month_end"
msgstr ""

#: ../../docstring maxframe.dataframe.Series.dt.is_month_end:1 of
msgid "Indicates whether the date is the last day of the month."
msgstr "指示日期是否为该月的最后一天。"

#: ../../docstring maxframe.dataframe.Series.dt.is_month_end of
msgid "返回"
msgstr ""

#: ../../docstring maxframe.dataframe.Series.dt.is_month_end:3 of
msgid ""
"For Series, returns a Series with boolean values. For DatetimeIndex, "
"returns a boolean array."
msgstr ""
"对于 Series，返回一个包含布尔值的 Series。对于 DatetimeIndex，返回一个"
"布尔数组。"

#: ../../docstring maxframe.dataframe.Series.dt.is_month_end of
msgid "返回类型"
msgstr ""

#: ../../docstring maxframe.dataframe.Series.dt.is_month_end:9 of
msgid ":py:obj:`is_month_start`"
msgstr ""

#: ../../docstring maxframe.dataframe.Series.dt.is_month_end:10 of
msgid ""
"Return a boolean indicating whether the date is the first day of the "
"month."
msgstr "返回一个布尔值，指示日期是否为该月的第一天。"

#: ../../docstring maxframe.dataframe.Series.dt.is_month_end:12 of
msgid ":py:obj:`is_month_end`"
msgstr ""

#: ../../docstring maxframe.dataframe.Series.dt.is_month_end:13 of
msgid "Return a boolean indicating whether the date is the last day of the month."
msgstr "返回一个布尔值，指示日期是否为该月的最后一天。"

#: ../../docstring maxframe.dataframe.Series.dt.is_month_end:16 of
msgid "示例"
msgstr ""

#: ../../docstring maxframe.dataframe.Series.dt.is_month_end:17 of
msgid ""
"This method is available on Series with datetime values under the ``.dt``"
" accessor, and directly on DatetimeIndex."
msgstr ""
"此方法适用于具有 datetime 值的 Series 的 ``.dt`` 访问器，以及直接用于 "
"DatetimeIndex。"

