#: ../../source/reference/dataframe/generated/maxframe.dataframe.Series.at.rst:2
msgid "maxframe.dataframe.Series.at"
msgstr ""

#: maxframe.dataframe.Series.at:1 of
msgid "Access a single value for a row/column label pair."
msgstr "访问行/列标签对的单个值。"

#: maxframe.dataframe.Series.at:3 of
msgid ""
"Similar to ``loc``, in that both provide label-based lookups. Use ``at`` "
"if you only need to get or set a single value in a DataFrame or Series."
msgstr ""
"与 ``loc`` 类似，两者都提供基于标签的查找。如果只需要获取或设置 DataFrame"
" 或 Series 中的单个值，请使用 ``at``。"

#: maxframe.dataframe.Series.at of
msgid "抛出"
msgstr ""

#: maxframe.dataframe.Series.at:7 of
msgid "If 'label' does not exist in DataFrame."
msgstr "如果 'label' 在 DataFrame 中不存在。"

#: maxframe.dataframe.Series.at:11 of
msgid ":py:obj:`DataFrame.iat`"
msgstr ""

#: maxframe.dataframe.Series.at:12 of
msgid "Access a single value for a row/column pair by integer position."
msgstr "通过整数位置访问行/列对的单个值。"

#: maxframe.dataframe.Series.at:14 of
msgid ":py:obj:`DataFrame.loc`"
msgstr ""

#: maxframe.dataframe.Series.at:15 of
msgid "Access a group of rows and columns by label(s)."
msgstr "通过标签访问一组行和列。"

#: maxframe.dataframe.Series.at:17 of
msgid ":py:obj:`Series.at`"
msgstr ""

#: maxframe.dataframe.Series.at:18 of
msgid "Access a single value using a label."
msgstr "使用标签访问单个值。"

#: maxframe.dataframe.Series.at:21 of
msgid "示例"
msgstr ""

#: maxframe.dataframe.Series.at:31 of
msgid "Get value at specified row/column pair"
msgstr "获取指定行/列对的值"

#: maxframe.dataframe.Series.at:36 of
msgid ""
"# Set value at specified row/column pair # # >>> df.at[4, 'B'] = 10 # >>>"
" df.at[4, 'B'] # 10"
msgstr "# 设置指定行/列对的值 # # >>> df.at[4, 'B'] = 10 # >>> df.at[4, 'B'] # 10"

#: maxframe.dataframe.Series.at:42 of
msgid "Get value within a Series"
msgstr "获取 Series 中的值"

