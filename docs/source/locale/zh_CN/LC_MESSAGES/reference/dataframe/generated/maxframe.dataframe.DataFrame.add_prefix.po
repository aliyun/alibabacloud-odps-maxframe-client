msgstr "使用字符串 `suffix` 作为后缀添加到行标签。"

#: maxframe.dataframe.indexing.add_prefix_suffix.df_add_prefix:17 of
msgid ":py:obj:`DataFrame.add_suffix`"
msgstr ""

