#: maxframe.dataframe.indexing.add_prefix_suffix.df_add_prefix:1 of
msgid "Prefix labels with string `prefix`."
msgstr "使用字符串 `prefix` 作为前缀添加到标签。"

#: maxframe.dataframe.indexing.add_prefix_suffix.df_add_prefix:3 of
msgid ""
"For Series, the row labels are prefixed. For DataFrame, the column labels"
" are prefixed."
msgstr "对于 Series，行标签会被加上前缀。对于 DataFrame，列标签会被加上前缀。"

#: maxframe.dataframe.indexing.add_prefix_suffix.df_add_prefix of
msgid "参数"
msgstr ""

#: maxframe.dataframe.indexing.add_prefix_suffix.df_add_prefix:6 of
msgid "The string to add before each label."
msgstr "要在每个标签前添加的字符串。"

#: maxframe.dataframe.indexing.add_prefix_suffix.df_add_prefix of
msgid "返回"
msgstr ""

#: maxframe.dataframe.indexing.add_prefix_suffix.df_add_prefix:9 of
msgid "New Series or DataFrame with updated labels."
msgstr "带有更新后标签的新 Series 或 DataFrame。"

#: maxframe.dataframe.indexing.add_prefix_suffix.df_add_prefix of
msgid "返回类型"
msgstr ""

