#: maxframe.dataframe.extensions.flatjson.series_flatjson:1 of
msgid "Flat JSON object in the series to a dataframe according to JSON query."
msgstr "将 Series 中的 JSON 对象根据 JSON 查询展平为 DataFrame。"

#: maxframe.dataframe.extensions.flatjson.series_flatjson of
msgid "参数"
msgstr ""

#: maxframe.dataframe.extensions.flatjson.series_flatjson:3 of
msgid "The series of json strings."
msgstr "JSON 字符串的 Series。"

#: maxframe.dataframe.extensions.flatjson.series_flatjson:5 of
msgid ""
"The JSON query paths for each generated column. The path format should "
"follow [RFC9535](https://datatracker.ietf.org/doc/rfc9535/)."
msgstr ""
"每个生成列的 JSON 查询路径。路径格式应遵循 [RFC9535](https://datatracker."
"ietf.org/doc/rfc9535/)。"

#: maxframe.dataframe.extensions.flatjson.series_flatjson:8 of
msgid "Specify dtypes of returned DataFrame. Can't work with dtype."
msgstr "指定返回 DataFrame 的数据类型。不能与 dtype 同时使用。"

#: maxframe.dataframe.extensions.flatjson.series_flatjson:10 of
msgid "Specify dtype of returned Series. Can't work with dtypes."
msgstr "指定返回 Series 的数据类型。不能与 dtypes 同时使用。"

#: maxframe.dataframe.extensions.flatjson.series_flatjson:12 of
msgid "Specify name of the returned Series."
msgstr "指定返回 Series 的名称。"

#: maxframe.dataframe.extensions.flatjson.series_flatjson of
msgid "返回"
msgstr ""

#: maxframe.dataframe.extensions.flatjson.series_flatjson:15 of
msgid "Result of DataFrame when dtypes specified, else Series."
msgstr "当指定 dtypes 时返回 DataFrame，否则返回 Series。"

