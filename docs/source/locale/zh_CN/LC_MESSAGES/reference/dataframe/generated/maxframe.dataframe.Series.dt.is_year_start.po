#: ../../source/reference/dataframe/generated/maxframe.dataframe.Series.dt.is_year_start.rst:2
msgid "maxframe.dataframe.Series.dt.is_year_start"
msgstr ""

#: ../../docstring maxframe.dataframe.Series.dt.is_year_start:1 of
msgid "Indicate whether the date is the first day of a year."
msgstr "指示日期是否为一年中的第一天。"

#: ../../docstring maxframe.dataframe.Series.dt.is_year_start of
msgid "返回"
msgstr ""

#: ../../docstring maxframe.dataframe.Series.dt.is_year_start:3 of
msgid ""
"The same type as the original data with boolean values. Series will have "
"the same name and index. DatetimeIndex will have the same name."
msgstr ""
"与原始数据类型相同，包含布尔值。Series 将具有相同的名称和索引。"
"DatetimeIndex 将具有相同的名称。"

#: ../../docstring maxframe.dataframe.Series.dt.is_year_start of
msgid "返回类型"
msgstr ""

#: ../../docstring maxframe.dataframe.Series.dt.is_year_start:10 of
msgid ":py:obj:`is_year_end`"
msgstr ""

#: ../../docstring maxframe.dataframe.Series.dt.is_year_start:11 of
msgid "Similar property indicating the last day of the year."
msgstr "类似的属性，指示一年中的最后一天。"

#: ../../docstring maxframe.dataframe.Series.dt.is_year_start:14 of
msgid "示例"
msgstr ""

#: ../../docstring maxframe.dataframe.Series.dt.is_year_start:15 of
msgid ""
"This method is available on Series with datetime values under the ``.dt``"
" accessor, and directly on DatetimeIndex."
msgstr ""
"此方法适用于具有 datetime 值的 Series（通过 ``.dt`` 访问器）以及直接作用"
"于 DatetimeIndex。"

