#: ../../source/reference/dataframe/generated/maxframe.dataframe.Series.explode.rst:2
msgid "maxframe.dataframe.Series.explode"
msgstr ""

#: maxframe.dataframe.misc.explode.series_explode:1 of
msgid "Transform each element of a list-like to a row."
msgstr "将列表状的每个元素转换为一行。"

#: maxframe.dataframe.misc.explode.series_explode of
msgid "参数"
msgstr ""

#: maxframe.dataframe.misc.explode.series_explode:3 of
msgid "If True, the resulting index will be labeled 0, 1, …, n - 1."
msgstr "如果为 True，结果索引将标记为 0, 1, …, n - 1。"

#: maxframe.dataframe.misc.explode.series_explode of
msgid "返回"
msgstr ""

#: maxframe.dataframe.misc.explode.series_explode:6 of
msgid "Exploded lists to rows; index will be duplicated for these rows."
msgstr "将列表展开为行；索引将在这些行中重复。"

#: maxframe.dataframe.misc.explode.series_explode of
msgid "返回类型"
msgstr ""

#: maxframe.dataframe.misc.explode.series_explode:11 of
msgid ":py:obj:`Series.str.split`"
msgstr ""

#: maxframe.dataframe.misc.explode.series_explode:12 of
msgid "Split string values on specified separator."
msgstr "在指定分隔符上拆分字符串值。"

#: maxframe.dataframe.misc.explode.series_explode:14 of
msgid ":py:obj:`Series.unstack`"
msgstr ""

#: maxframe.dataframe.misc.explode.series_explode:15 of
msgid "Unstack, a.k.a. pivot, Series with MultiIndex to produce DataFrame."
msgstr "取消堆叠，即将具有多级索引的 Series 转换为 DataFrame。"

#: maxframe.dataframe.misc.explode.series_explode:17 of
msgid ":py:obj:`DataFrame.melt`"
msgstr ""

#: maxframe.dataframe.misc.explode.series_explode:18 of
msgid "Unpivot a DataFrame from wide format to long format."
msgstr "将 DataFrame 从宽格式转换为长格式。"

#: maxframe.dataframe.misc.explode.series_explode:20 of
msgid ":py:obj:`DataFrame.explode`"
msgstr ""

#: maxframe.dataframe.misc.explode.series_explode:21 of
msgid "Explode a DataFrame from list-like columns to long format."
msgstr "将包含列表状列的 DataFrame 展开为长格式。"

#: maxframe.dataframe.misc.explode.series_explode:24 of
msgid "备注"
msgstr ""

#: maxframe.dataframe.misc.explode.series_explode:25 of
msgid ""
"This routine will explode list-likes including lists, tuples, Series, and"
" np.ndarray. The result dtype of the subset rows will be object. Scalars "
"will be returned unchanged. Empty list-likes will result in a np.nan for "
"that row."
msgstr ""
"此函数会将列表状数据（包括列表、元组、Series 和 np.ndarray）展开。子集行"
"的结果 dtype 为 object。标量将保持不变返回。空的列表状数据会导致该行结果"
"为 np.nan。"

