msgid "The previous expression is equivalent to"
msgstr "前一个表达式等价于"

#: maxframe.dataframe.misc.eval.df_query:119 of
msgid "For columns with spaces in their name, you can use backtick quoting."
msgstr "对于名称中包含空格的列，您可以使用反引号引用。"

