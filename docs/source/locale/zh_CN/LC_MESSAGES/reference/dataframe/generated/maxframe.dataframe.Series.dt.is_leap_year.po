#: ../../source/reference/dataframe/generated/maxframe.dataframe.Series.dt.is_leap_year.rst:2
msgid "maxframe.dataframe.Series.dt.is_leap_year"
msgstr ""

#: ../../docstring maxframe.dataframe.Series.dt.is_leap_year:1 of
msgid "Boolean indicator if the date belongs to a leap year."
msgstr "日期是否属于闰年的布尔指示器。"

#: ../../docstring maxframe.dataframe.Series.dt.is_leap_year:3 of
msgid ""
"A leap year is a year, which has 366 days (instead of 365) including 29th"
" of February as an intercalary day. Leap years are years which are "
"multiples of four with the exception of years divisible by 100 but not by"
" 400."
msgstr ""
"闰年是包含 366 天（而非 365 天）的年份，其中包括 2 月 29 日作为闰日。闰年"
"是指能被 4 整除的年份，但能被 100 整除而不能被 400 整除的年份除外。"

#: ../../docstring maxframe.dataframe.Series.dt.is_leap_year of
msgid "返回"
msgstr ""

#: ../../docstring maxframe.dataframe.Series.dt.is_leap_year:8 of
msgid "Booleans indicating if dates belong to a leap year."
msgstr "表示日期是否属于闰年的布尔值。"

#: ../../docstring maxframe.dataframe.Series.dt.is_leap_year of
msgid "返回类型"
msgstr ""

