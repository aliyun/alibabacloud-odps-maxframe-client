#: ../../source/reference/dataframe/generated/maxframe.dataframe.read_odps_query.rst:2
msgid "maxframe.dataframe.read\\_odps\\_query"
msgstr ""

#: maxframe.dataframe.datasource.read_odps_query.read_odps_query:1 of
msgid "Read data from a MaxCompute (ODPS) query into DataFrame."
msgstr "从 MaxCompute (ODPS) 查询中读取数据到 DataFrame。"

#: maxframe.dataframe.datasource.read_odps_query.read_odps_query:3 of
msgid ""
"Supports specifying some columns as indexes. If not specified, RangeIndex"
" will be generated."
msgstr "支持将某些列指定为索引。如果未指定，将生成 RangeIndex。"

#: ../../source/reference/dataframe/generated/maxframe.dataframe.read_odps_query.rst
msgid "参数"
msgstr ""

#: maxframe.dataframe.datasource.read_odps_query.read_odps_query:6 of
msgid "MaxCompute SQL statement."
msgstr "MaxCompute SQL 语句。"

#: maxframe.dataframe.datasource.read_odps_query.read_odps_query:8 of
msgid "Columns to be specified as indexes."
msgstr "指定为索引的列。"

#: maxframe.dataframe.datasource.read_odps_query.read_odps_query:10 of
msgid "Whether to convert string columns to binary."
msgstr "是否将字符串列转换为二进制。"

#: maxframe.dataframe.datasource.read_odps_query.read_odps_query:12 of
msgid "User specified SQL hints."
msgstr "用户指定的 SQL 提示。"

#: maxframe.dataframe.datasource.read_odps_query.read_odps_query:14 of
msgid "Prefix for anonymous columns, '_anon_col_' by default."
msgstr "匿名列的前缀，默认为 '_anon_col_'。"

#: maxframe.dataframe.datasource.read_odps_query.read_odps_query:16 of
msgid ""
"Skip resolving output schema before execution. Once this is configured, "
"the output DataFrame cannot be inputs of other DataFrame operators before"
" execution."
msgstr ""
"跳过执行前解析输出模式。一旦配置了此选项，输出 DataFrame 在执行前不能作为"
"其他 DataFrame 运算符的输入。"

#: maxframe.dataframe.datasource.read_odps_query.read_odps_query:20 of
msgid ""
"Back-end data type applied to the resultant DataFrame (still "
"experimental)."
msgstr "应用于结果 DataFrame 的后端数据类型（仍处于实验阶段）。"

#: ../../source/reference/dataframe/generated/maxframe.dataframe.read_odps_query.rst
msgid "返回"
msgstr ""

#: maxframe.dataframe.datasource.read_odps_query.read_odps_query:23 of
msgid "**result** -- DataFrame read from MaxCompute (ODPS) table"
msgstr "**result** -- 从 MaxCompute (ODPS) 表中读取的 DataFrame"

#: ../../source/reference/dataframe/generated/maxframe.dataframe.read_odps_query.rst
msgid "返回类型"
msgstr ""

