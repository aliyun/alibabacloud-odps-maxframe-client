#: ../../source/reference/dataframe/generated/maxframe.dataframe.DataFrame.droplevel.rst:2
msgid "maxframe.dataframe.DataFrame.droplevel"
msgstr ""

#: maxframe.dataframe.indexing.droplevel.df_series_droplevel:1 of
msgid "Return Series/DataFrame with requested index / column level(s) removed."
msgstr "返回删除了请求的索引/列层级的 Series/DataFrame。"

#: maxframe.dataframe.indexing.droplevel.df_series_droplevel of
msgid "参数"
msgstr ""

#: maxframe.dataframe.indexing.droplevel.df_series_droplevel:3 of
msgid ""
"If a string is given, must be the name of a level If list-like, elements "
"must be names or positional indexes of levels."
msgstr ""
"如果给定的是字符串，则必须是层级的名称；如果是类列表，则元素必须是层级的"
"名称或位置索引。"

#: maxframe.dataframe.indexing.droplevel.df_series_droplevel:7 of
msgid ""
"Axis along which the level(s) is removed:  * 0 or 'index': remove "
"level(s) in column. * 1 or 'columns': remove level(s) in row.  For "
"`Series` this parameter is unused and defaults to 0."
msgstr ""
"删除层级的轴：  * 0 或 'index'：删除列中的层级。 * 1 或 'columns'：删除"
"行中的层级。  对于 `Series` 此参数未使用，默认为 0。"

#: maxframe.dataframe.indexing.droplevel.df_series_droplevel:7 of
msgid "Axis along which the level(s) is removed:"
msgstr ""

#: maxframe.dataframe.indexing.droplevel.df_series_droplevel:9 of
msgid "0 or 'index': remove level(s) in column."
msgstr ""

#: maxframe.dataframe.indexing.droplevel.df_series_droplevel:10 of
msgid "1 or 'columns': remove level(s) in row."
msgstr ""

#: maxframe.dataframe.indexing.droplevel.df_series_droplevel:12 of
msgid "For `Series` this parameter is unused and defaults to 0."
msgstr ""

#: maxframe.dataframe.indexing.droplevel.df_series_droplevel of
msgid "返回"
msgstr ""

#: maxframe.dataframe.indexing.droplevel.df_series_droplevel:15 of
msgid "Series/DataFrame with requested index / column level(s) removed."
msgstr "删除了请求的索引/列层级的 Series/DataFrame。"

#: maxframe.dataframe.indexing.droplevel.df_series_droplevel of
msgid "返回类型"
msgstr ""

