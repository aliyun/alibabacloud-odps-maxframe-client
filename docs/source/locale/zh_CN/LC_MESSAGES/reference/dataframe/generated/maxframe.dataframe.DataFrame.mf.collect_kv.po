msgid ""
"The field names to be merged are specified by columns kv_delim is to "
"delimit the key and value and '=' is default item_delim is to delimit the"
" Key-Value pairs, ',' is default The new column name is specified by "
"kv_col, 'kv_col' is default"
msgstr ""
