#: ../../source/reference/dataframe/generated/maxframe.dataframe.Series.dict.get.rst:2
msgid "maxframe.dataframe.Series.dict.get"
msgstr ""

#: maxframe.dataframe.accessors.dict_.getitem.series_dict_getitem:1
#: maxframe.dataframe.accessors.dict_.getitem.series_dict_getitem:15 of
msgid "Get the value by the key of each dict in the Series."
msgstr "获取 Series 中每个字典对应键的值。"

#: maxframe.dataframe.accessors.dict_.getitem.series_dict_getitem of
msgid "参数"
msgstr ""

#: maxframe.dataframe.accessors.dict_.getitem.series_dict_getitem:3 of
msgid "The key to check, must be in the same key type of the dict."
msgstr "要查找的键，必须与字典中的键类型相同。"

#: maxframe.dataframe.accessors.dict_.getitem.series_dict_getitem:5 of
msgid "The value to return if the key is not in the dict, by default None."
msgstr "如果键不在字典中时返回的值，默认为 None。"

#: maxframe.dataframe.accessors.dict_.getitem.series_dict_getitem of
msgid "返回"
msgstr ""

#: maxframe.dataframe.accessors.dict_.getitem.series_dict_getitem:8 of
msgid ""
"A Series with the dict value's data type. The value will be "
"``default_value`` if the key is not in the dict, or ``None`` if the dict "
"is None."
msgstr ""
"一个具有字典值数据类型的 Series。如果键不在字典中，则值为 ``default_value"
"``，如果字典为 None，则值为 ``None``。"

#: maxframe.dataframe.accessors.dict_.getitem.series_dict_getitem of
msgid "返回类型"
msgstr ""

#: maxframe.dataframe.accessors.dict_.getitem.series_dict_getitem:14 of
msgid ":py:obj:`Series.dict.__getitem__`"
msgstr ""

#: maxframe.dataframe.accessors.dict_.getitem.series_dict_getitem:18 of
msgid "示例"
msgstr ""

#: maxframe.dataframe.accessors.dict_.getitem.series_dict_getitem:19 of
msgid "Create a series with dict type data."
msgstr "创建一个包含字典类型数据的 Series。"

