#: ../../source/reference/dataframe/generated/maxframe.dataframe.DataFrame.insert.rst:2
msgid "maxframe.dataframe.DataFrame.insert"
msgstr ""

#: maxframe.dataframe.indexing.insert.df_insert:1 of
msgid "Insert column into DataFrame at specified location."
msgstr "在指定位置将列插入 DataFrame。"

#: maxframe.dataframe.indexing.insert.df_insert:3 of
msgid ""
"Raises a ValueError if `column` is already contained in the DataFrame, "
"unless `allow_duplicates` is set to True."
msgstr ""
"如果 `column` 已经包含在 DataFrame 中，则会引发 ValueError，除非将 `allow"
"_duplicates` 设置为 True。"

#: ../../source/reference/dataframe/generated/maxframe.dataframe.DataFrame.insert.rst
msgid "参数"
msgstr ""

#: maxframe.dataframe.indexing.insert.df_insert:6 of
msgid "Insertion index. Must verify 0 <= loc <= len(columns)."
msgstr "插入位置索引。必须满足 0 <= loc <= len(columns)。"

#: maxframe.dataframe.indexing.insert.df_insert:8 of
msgid "Label of the inserted column."
msgstr "插入列的标签。"

