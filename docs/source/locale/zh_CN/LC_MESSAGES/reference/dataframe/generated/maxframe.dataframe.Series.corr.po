#: ../../source/reference/dataframe/generated/maxframe.dataframe.Series.corr.rst:2
msgid "maxframe.dataframe.Series.corr"
msgstr ""

#: maxframe.dataframe.statistics.corr.series_corr:1 of
msgid "Compute correlation with `other` Series, excluding missing values."
msgstr "计算与 `other` Series 的相关性，排除缺失值。"

#: maxframe.dataframe.statistics.corr.series_corr of
msgid "参数"
msgstr ""

#: maxframe.dataframe.statistics.corr.series_corr:3 of
msgid "Series with which to compute the correlation."
msgstr "用于计算相关性的 Series。"

#: maxframe.dataframe.statistics.corr.series_corr:5 of
msgid ""
"Method used to compute correlation:  - pearson : Standard correlation "
"coefficient - kendall : Kendall Tau correlation coefficient - spearman : "
"Spearman rank correlation - callable: Callable with input two 1d ndarrays"
" and returning a float.  .. note::     kendall, spearman and callables "
"not supported on multiple chunks yet."
msgstr ""
"用于计算相关性的方法：  - pearson : 标准相关系数 - kendall : Kendall Tau "
"相关系数 - spearman : Spearman 秩相关系数 - callable: 输入两个一维 "
"ndarray 并返回一个浮点数的可调用对象。  .. note::     kendall、spearman "
"和可调用对象尚不支持多个 chunk。"

#: maxframe.dataframe.statistics.corr.series_corr:5 of
msgid "Method used to compute correlation:"
msgstr "用于计算相关性的方法："

#: maxframe.dataframe.statistics.corr.series_corr:7 of
msgid "pearson : Standard correlation coefficient"
msgstr "pearson：标准相关系数"

#: maxframe.dataframe.statistics.corr.series_corr:8 of
msgid "kendall : Kendall Tau correlation coefficient"
msgstr "kendall：Kendall Tau 相关系数"

#: maxframe.dataframe.statistics.corr.series_corr:9 of
msgid "spearman : Spearman rank correlation"
msgstr "spearman：Spearman 秩相关"

#: maxframe.dataframe.statistics.corr.series_corr:10 of
msgid "callable: Callable with input two 1d ndarrays and returning a float."
msgstr "callable：接受两个一维 ndarray 并返回浮点数的可调用对象。"

#: maxframe.dataframe.statistics.corr.series_corr:13 of
msgid "kendall, spearman and callables not supported on multiple chunks yet."
msgstr "kendall、spearman 和可调用对象尚不支持多个分块。"

#: maxframe.dataframe.statistics.corr.series_corr:15 of
msgid "Minimum number of observations needed to have a valid result."
msgstr "获得有效结果所需的最小观测数量。"

#: maxframe.dataframe.statistics.corr.series_corr of
msgid "返回"
msgstr ""

#: maxframe.dataframe.statistics.corr.series_corr:18 of
msgid "Correlation with other."
msgstr "与另一个对象的相关性。"

#: maxframe.dataframe.statistics.corr.series_corr of
msgid "返回类型"
msgstr ""

#: maxframe.dataframe.statistics.corr.series_corr:23 of
msgid ":py:obj:`DataFrame.corr`"
msgstr ""

#: maxframe.dataframe.statistics.corr.series_corr:24 of
msgid "Compute pairwise correlation between columns."
msgstr "计算列之间的成对相关性。"

#: maxframe.dataframe.statistics.corr.series_corr:26 of
msgid ":py:obj:`DataFrame.corrwith`"
msgstr ""

#: maxframe.dataframe.statistics.corr.series_corr:27 of
msgid "Compute pairwise correlation with another DataFrame or Series."
msgstr "计算与另一个 DataFrame 或 Series 的成对相关性。"

