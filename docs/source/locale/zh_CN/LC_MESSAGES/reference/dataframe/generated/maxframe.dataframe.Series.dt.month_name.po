#: ../../source/reference/dataframe/generated/maxframe.dataframe.Series.dt.month_name.rst:2
msgid "maxframe.dataframe.Series.dt.month_name"
msgstr ""

#: of
#: pandas.core.accessor.PandasDelegate._add_delegate_accessors.<locals>._create_delegator_method.<locals>.f:1
msgid "Return the month names with specified locale."
msgstr "返回指定语言环境下的月份名称。"

#: of
#: pandas.core.accessor.PandasDelegate._add_delegate_accessors.<locals>._create_delegator_method.<locals>.f
msgid "参数"
msgstr ""

#: of
#: pandas.core.accessor.PandasDelegate._add_delegate_accessors.<locals>._create_delegator_method.<locals>.f:3
msgid ""
"Locale determining the language in which to return the month name. "
"Default is English locale (``'en_US.utf8'``). Use the command ``locale "
"-a`` on your terminal on Unix systems to find your locale language code."
msgstr ""
"决定返回月份名称所用语言的区域设置。默认为英语区域设置（``'en_US.utf8'``"
"）。在 Unix 系统上，可以使用命令 ``locale -a`` 查找你的区域语言代码。"

#: of
#: pandas.core.accessor.PandasDelegate._add_delegate_accessors.<locals>._create_delegator_method.<locals>.f
msgid "返回"
msgstr ""

#: of
#: pandas.core.accessor.PandasDelegate._add_delegate_accessors.<locals>._create_delegator_method.<locals>.f:9
msgid "Series or Index of month names."
msgstr "包含月份名称的 Series 或 Index。"

#: of
#: pandas.core.accessor.PandasDelegate._add_delegate_accessors.<locals>._create_delegator_method.<locals>.f
msgid "返回类型"
msgstr ""

#: of
#: pandas.core.accessor.PandasDelegate._add_delegate_accessors.<locals>._create_delegator_method.<locals>.f:13
msgid "示例"
msgstr ""

#: of
#: pandas.core.accessor.PandasDelegate._add_delegate_accessors.<locals>._create_delegator_method.<locals>.f:34
msgid ""
"Using the ``locale`` parameter you can set a different locale language, "
"for example: ``idx.month_name(locale='pt_BR.utf8')`` will return month "
"names in Brazilian Portuguese language."
msgstr ""
"使用 ``locale`` 参数可以设置不同的区域语言，例如：``idx.month_name(locale"
"='pt_BR.utf8')`` 将返回巴西葡萄牙语的月份名称。"

