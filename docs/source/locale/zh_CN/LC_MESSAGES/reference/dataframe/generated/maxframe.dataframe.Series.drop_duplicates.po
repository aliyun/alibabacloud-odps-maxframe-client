msgid "maxframe.dataframe.Series.drop\\_duplicates"
msgstr ""

#: maxframe.dataframe.misc.drop_duplicates.series_drop_duplicates:1 of
msgid "Return Series with duplicate values removed."
msgstr "返回去除重复值后的 Series。"

#: maxframe.dataframe.misc.drop_duplicates.series_drop_duplicates of
msgid "参数"
msgstr ""

#: maxframe.dataframe.misc.drop_duplicates.series_drop_duplicates:3 of
msgid ""
"Method to handle dropping duplicates:  - 'first' : Drop duplicates except"
" for the first occurrence. - 'last' : Drop duplicates except for the last"
" occurrence. - 'any' : Drop duplicates except for a random occurrence. - "
"``False`` : Drop all duplicates."
msgstr ""
"处理去除重复值的方法：  - 'first' : 保留第一次出现的值，去除其余重复项。 "
"- 'last' : 保留最后一次出现的值，去除其余重复项。 - 'any' : 随机保留一个"
"出现的值，去除其余重复项。 - ``False`` : 去除所有重复项。"

#: maxframe.dataframe.misc.drop_duplicates.series_drop_duplicates:3 of
msgid "Method to handle dropping duplicates:"
msgstr ""

#: maxframe.dataframe.misc.drop_duplicates.series_drop_duplicates:5 of
msgid "'first' : Drop duplicates except for the first occurrence."
msgstr ""

#: maxframe.dataframe.misc.drop_duplicates.series_drop_duplicates:6 of
msgid "'last' : Drop duplicates except for the last occurrence."
msgstr ""

#: maxframe.dataframe.misc.drop_duplicates.series_drop_duplicates:7 of
msgid "'any' : Drop duplicates except for a random occurrence."
msgstr ""

#: maxframe.dataframe.misc.drop_duplicates.series_drop_duplicates:8 of
msgid "``False`` : Drop all duplicates."
msgstr ""

#: maxframe.dataframe.misc.drop_duplicates.series_drop_duplicates:10 of
msgid "If ``True``, performs operation inplace and returns None."
msgstr "如果为 ``True``，则就地执行操作并返回 None。"

#: maxframe.dataframe.misc.drop_duplicates.series_drop_duplicates of
msgid "返回"
msgstr ""

#: maxframe.dataframe.misc.drop_duplicates.series_drop_duplicates:13 of
msgid "Series with duplicates dropped."
msgstr "去除重复值后的 Series。"

#: maxframe.dataframe.misc.drop_duplicates.series_drop_duplicates of
msgid "返回类型"
msgstr ""

