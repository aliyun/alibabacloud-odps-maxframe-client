msgid "maxframe.dataframe.Series.round"
msgstr ""

#: maxframe.dataframe.arithmetic.round.round:1 of
msgid "Round each value in a Series to the given number of decimals."
msgstr "将 Series 中的每个值四舍五入到指定的小数位数。"

#: maxframe.dataframe.arithmetic.round.round of
msgid "参数"
msgstr ""

#: maxframe.dataframe.arithmetic.round.round:3 of
msgid ""
"Number of decimal places to round to. If decimals is negative, it "
"specifies the number of positions to the left of the decimal point."
msgstr "要四舍五入到的小数位数。如果 decimals 为负数，则表示小数点左边的位数。"

#: maxframe.dataframe.arithmetic.round.round of
msgid "返回"
msgstr ""

#: maxframe.dataframe.arithmetic.round.round:7 of
msgid "Rounded values of the Series."
msgstr "Series 的四舍五入值。"

#: maxframe.dataframe.arithmetic.round.round of
msgid "返回类型"
msgstr ""

#: maxframe.dataframe.arithmetic.round.round:12 of
msgid ":py:obj:`numpy.around`"
msgstr ""

#: maxframe.dataframe.arithmetic.round.round:13 of
msgid "Round values of an np.array."
msgstr "对 np.array 的值进行四舍五入。"

#: maxframe.dataframe.arithmetic.round.round:15 of
msgid ":py:obj:`DataFrame.round`"
msgstr ""

#: maxframe.dataframe.arithmetic.round.round:16 of
msgid "Round values of a DataFrame."
msgstr "对 DataFrame 的值进行四舍五入。"

