#: ../../source/reference/dataframe/generated/maxframe.dataframe.DataFrame.tail.rst:2
msgid "maxframe.dataframe.DataFrame.tail"
msgstr ""

#: maxframe.dataframe.indexing.iloc.tail:1 of
msgid "Return the last `n` rows."
msgstr "返回最后 `n` 行。"

#: maxframe.dataframe.indexing.iloc.tail:3 of
msgid ""
"This function returns last `n` rows from the object based on position. It"
" is useful for quickly verifying data, for example, after sorting or "
"appending rows."
msgstr ""
"此函数根据位置从对象中返回最后 `n` 行。它对于快速验证数据非常有用，例如在"
"排序或追加行之后。"

#: maxframe.dataframe.indexing.iloc.tail:7 of
msgid ""
"For negative values of `n`, this function returns all rows except the "
"first `n` rows, equivalent to ``df[n:]``."
msgstr "对于 `n` 的负数值，此函数返回除前 `n` 行之外的所有行，等效于 ``df[n:]``。"

#: maxframe.dataframe.indexing.iloc.tail of
msgid "参数"
msgstr ""

#: maxframe.dataframe.indexing.iloc.tail:10 of
msgid "Number of rows to select."
msgstr "要选择的行数。"

#: maxframe.dataframe.indexing.iloc.tail of
msgid "返回"
msgstr ""

#: maxframe.dataframe.indexing.iloc.tail:13 of
msgid "The last `n` rows of the caller object."
msgstr "调用对象的最后 `n` 行。"

#: maxframe.dataframe.indexing.iloc.tail of
msgid "返回类型"
msgstr ""

#: maxframe.dataframe.indexing.iloc.tail:18 of
msgid ":py:obj:`DataFrame.head`"
msgstr ""

#: maxframe.dataframe.indexing.iloc.tail:19 of
msgid "The first `n` rows of the caller object."
msgstr "调用对象的前 `n` 行。"

#: maxframe.dataframe.indexing.iloc.tail:22 of
msgid "示例"
msgstr ""

#: maxframe.dataframe.indexing.iloc.tail:38 of
msgid "Viewing the last 5 lines"
msgstr "查看最后 5 行"

#: maxframe.dataframe.indexing.iloc.tail:48 of
msgid "Viewing the last `n` lines (three in this case)"
msgstr "查看最后 `n` 行（本例中为三行）"

#: maxframe.dataframe.indexing.iloc.tail:56 of
msgid "For negative values of `n`"
msgstr "对于 `n` 的负数值"

