#: ../../source/reference/dataframe/generated/maxframe.dataframe.Index.set_names.rst:2
msgid "maxframe.dataframe.Index.set\\_names"
msgstr ""

#: maxframe.dataframe.indexing.rename.index_set_names:1 of
msgid "Set Index or MultiIndex name."
msgstr "设置 Index 或 MultiIndex 的名称。"

#: maxframe.dataframe.indexing.rename.index_set_names:3 of
msgid "Able to set new names partially and by level."
msgstr "能够按层级部分地设置新名称。"

#: maxframe.dataframe.indexing.rename.index_set_names of
msgid "参数"
msgstr ""

#: maxframe.dataframe.indexing.rename.index_set_names:5 of
msgid "Name(s) to set."
msgstr "要设置的名称。"

#: maxframe.dataframe.indexing.rename.index_set_names:7 of
msgid ""
"If the index is a MultiIndex, level(s) to set (None for all levels). "
"Otherwise level must be None."
msgstr ""
"如果索引是 MultiIndex，则为要设置的层级（None 表示所有层级）。否则层级"
"必须为 None。"

#: maxframe.dataframe.indexing.rename.index_set_names:10 of
msgid ""
"Modifies the object directly, instead of creating a new Index or "
"MultiIndex."
msgstr "直接修改对象，而不是创建新的 Index 或 MultiIndex。"

#: maxframe.dataframe.indexing.rename.index_set_names of
msgid "返回"
msgstr ""

#: maxframe.dataframe.indexing.rename.index_set_names:14 of
msgid "The same type as the caller or None if inplace is True."
msgstr "与调用者相同类型的对象，如果 inplace 为 True 则返回 None。"

#: maxframe.dataframe.indexing.rename.index_set_names of
msgid "返回类型"
msgstr ""

#: maxframe.dataframe.indexing.rename.index_set_names:19 of
msgid ":py:obj:`Index.rename`"
msgstr ""

#: maxframe.dataframe.indexing.rename.index_set_names:20 of
msgid "Able to set new names without level."
msgstr "能够在不指定层级的情况下设置新名称。"

