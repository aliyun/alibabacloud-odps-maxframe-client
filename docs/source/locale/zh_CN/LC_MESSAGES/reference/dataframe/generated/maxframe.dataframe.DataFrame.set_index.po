#: ../../source/reference/dataframe/generated/maxframe.dataframe.DataFrame.set_index.rst:2
msgid "maxframe.dataframe.DataFrame.set\\_index"
msgstr ""

#: maxframe.dataframe.indexing.set_index.set_index:1 of
msgid "Set the DataFrame index using existing columns."
msgstr "使用现有列设置 DataFrame 索引。"

#: maxframe.dataframe.indexing.set_index.set_index:3 of
msgid ""
"Set the DataFrame index (row labels) using one or more existing columns. "
"The index can replace the existing index or expand on it."
msgstr ""
"使用一个或多个现有列设置 DataFrame 索引（行标签）。索引可以替换现有索引或"
"对其进行扩展。"

#: maxframe.dataframe.indexing.set_index.set_index of
msgid "参数"
msgstr ""

#: maxframe.dataframe.indexing.set_index.set_index:6 of
msgid ""
"This parameter can be either a single column key, or a list containing "
"column keys."
msgstr "此参数可以是单个列键，也可以是包含列键的列表。"

#: maxframe.dataframe.indexing.set_index.set_index:8 of
msgid "Delete columns to be used as the new index."
msgstr "删除要用作新索引的列。"

#: maxframe.dataframe.indexing.set_index.set_index:10 of
msgid "Whether to append columns to existing index."
msgstr "是否将列追加到现有索引。"

#: maxframe.dataframe.indexing.set_index.set_index:12 of
msgid "If True, modifies the DataFrame in place (do not create a new object)."
msgstr "如果为 True，则就地修改 DataFrame（不创建新对象）。"

#: maxframe.dataframe.indexing.set_index.set_index:14 of
msgid ""
"Check the new index for duplicates. Otherwise defer the check until "
"necessary. Setting to False will improve the performance of this method."
msgstr ""
"检查新索引是否包含重复项。否则将推迟检查直到必要时。设置为 False 将提高此"
"方法的性能。"

#: maxframe.dataframe.indexing.set_index.set_index of
msgid "返回"
msgstr ""

#: maxframe.dataframe.indexing.set_index.set_index:19 of
msgid "Changed row labels or None if ``inplace=True``."
msgstr "更改后的行标签，如果 ``inplace=True`` 则为 None。"

#: maxframe.dataframe.indexing.set_index.set_index of
msgid "返回类型"
msgstr ""

#: maxframe.dataframe.indexing.set_index.set_index:24 of
msgid ":py:obj:`DataFrame.reset_index`"
msgstr ""

#: maxframe.dataframe.indexing.set_index.set_index:25 of
msgid "Opposite of set_index."
msgstr "set_index 的反向操作。"

#: maxframe.dataframe.indexing.set_index.set_index:27 of
msgid ":py:obj:`DataFrame.reindex`"
msgstr ""

#: maxframe.dataframe.indexing.set_index.set_index:28 of
msgid "Change to new indices or expand indices."
msgstr "更改为新索引或扩展索引。"

#: maxframe.dataframe.indexing.set_index.set_index:30 of
msgid ":py:obj:`DataFrame.reindex_like`"
msgstr ""

#: maxframe.dataframe.indexing.set_index.set_index:31 of
msgid "Change to same indices as other DataFrame."
msgstr "更改为与其他 DataFrame 相同的索引。"

