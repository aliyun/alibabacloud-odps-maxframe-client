#: maxframe.dataframe.missing.dropna.df_dropna:49 of
msgid "示例"
msgstr ""

#: maxframe.dataframe.missing.dropna.df_dropna:61 of
msgid "Drop the rows where at least one element is missing."
msgstr "删除至少有一个元素缺失的行。"

#: maxframe.dataframe.missing.dropna.df_dropna:67 of
msgid "Drop the rows where all elements are missing."
msgstr "删除所有元素都缺失的行。"

#: maxframe.dataframe.missing.dropna.df_dropna:75 of
msgid "Keep only the rows with at least 2 non-NA values."
msgstr "只保留至少有2个非NA值的行。"

#: maxframe.dataframe.missing.dropna.df_dropna:82 of
msgid "Define in which columns to look for missing values."
msgstr "定义在哪些列中查找缺失值。"

#: maxframe.dataframe.missing.dropna.df_dropna:88 of
msgid "Keep the DataFrame with valid entries in the same variable."
msgstr "将包含有效条目的DataFrame保留在同一变量中。"

