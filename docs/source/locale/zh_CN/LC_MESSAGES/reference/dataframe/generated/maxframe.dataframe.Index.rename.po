#: ../../source/reference/dataframe/generated/maxframe.dataframe.Index.rename.rst:2
msgid "maxframe.dataframe.Index.rename"
msgstr ""

#: maxframe.dataframe.indexing.rename.index_rename:1 of
msgid "Alter Index or MultiIndex name."
msgstr "更改 Index 或 MultiIndex 的名称。"

#: maxframe.dataframe.indexing.rename.index_rename:3 of
msgid ""
"Able to set new names without level. Defaults to returning new index. "
"Length of names must match number of levels in MultiIndex."
msgstr ""
"可以在不指定层级的情况下设置新名称。默认返回新的索引。名称的长度必须与 "
"MultiIndex 中的层级数量一致。"

#: maxframe.dataframe.indexing.rename.index_rename of
msgid "参数"
msgstr ""

#: maxframe.dataframe.indexing.rename.index_rename:6 of
msgid "Name(s) to set."
msgstr "要设置的名称。"

#: maxframe.dataframe.indexing.rename.index_rename:8 of
msgid ""
"Modifies the object directly, instead of creating a new Index or "
"MultiIndex."
msgstr "直接修改对象，而不是创建一个新的 Index 或 MultiIndex。"

#: maxframe.dataframe.indexing.rename.index_rename of
msgid "返回"
msgstr ""

#: maxframe.dataframe.indexing.rename.index_rename:12 of
msgid "The same type as the caller or None if inplace is True."
msgstr "与调用者相同类型的对象，如果 inplace 为 True 则返回 None。"

#: maxframe.dataframe.indexing.rename.index_rename of
msgid "返回类型"
msgstr ""

#: maxframe.dataframe.indexing.rename.index_rename:17 of
msgid ":py:obj:`Index.set_names`"
msgstr ""

#: maxframe.dataframe.indexing.rename.index_rename:18 of
msgid "Able to set new names partially and by level."
msgstr "可以按层级部分地设置新名称。"

#: maxframe.dataframe.indexing.rename.index_rename:21 of
msgid "示例"
msgstr ""

