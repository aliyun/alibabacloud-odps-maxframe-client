#: ../../source/reference/dataframe/generated/maxframe.dataframe.Series.update.rst:2
msgid "maxframe.dataframe.Series.update"
msgstr ""

#: maxframe.dataframe.merge.update.series_update:1 of
msgid "Modify Series in place using values from passed Series."
msgstr "使用传入的 Series 中的值就地修改 Series。"

#: maxframe.dataframe.merge.update.series_update:3 of
msgid "Uses non-NA values from passed Series to make updates. Aligns on index."
msgstr "使用传入的 Series 中的非 NA 值进行更新。按索引对齐。"

#: maxframe.dataframe.merge.update.series_update of
msgid "参数"
msgstr ""

#: maxframe.dataframe.merge.update.series_update:10 of
msgid "示例"
msgstr ""

#: maxframe.dataframe.merge.update.series_update:37 of
msgid ""
"If ``other`` contains NaNs the corresponding values are not updated in "
"the original Series."
msgstr "如果 ``other`` 包含 NaN，则原始 Series 中对应的值不会被更新。"

#: maxframe.dataframe.merge.update.series_update:48 of
msgid ""
"``other`` can also be a non-Series object type that is coercible into a "
"Series"
msgstr "``other`` 也可以是可强制转换为 Series 的非 Series 对象类型"

