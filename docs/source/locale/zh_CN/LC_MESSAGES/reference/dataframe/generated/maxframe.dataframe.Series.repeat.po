#: ../../source/reference/dataframe/generated/maxframe.dataframe.Series.repeat.rst:2
msgid "maxframe.dataframe.Series.repeat"
msgstr ""

#: maxframe.dataframe.misc.repeat.series_repeat:1 of
msgid "Repeat elements of a Series."
msgstr "重复 Series 的元素。"

#: maxframe.dataframe.misc.repeat.series_repeat:3 of
msgid ""
"Returns a new Series where each element of the current Series is repeated"
" consecutively a given number of times."
msgstr "返回一个新的 Series，其中当前 Series 的每个元素都连续重复指定次数。"

#: maxframe.dataframe.misc.repeat.series_repeat of
msgid "参数"
msgstr ""

#: maxframe.dataframe.misc.repeat.series_repeat:6 of
msgid ""
"The number of repetitions for each element. This should be a non-negative"
" integer. Repeating 0 times will return an empty Series."
msgstr "每个元素的重复次数。这应该是一个非负整数。重复 0 次将返回一个空的 Series。"

#: maxframe.dataframe.misc.repeat.series_repeat:10 of
msgid ""
"Must be ``None``. Has no effect but is accepted for compatibility with "
"numpy."
msgstr "必须为 ``None``。没有实际效果，但为了与 numpy 兼容而被接受。"

#: maxframe.dataframe.misc.repeat.series_repeat of
msgid "返回"
msgstr ""

#: maxframe.dataframe.misc.repeat.series_repeat:14 of
msgid "Newly created Series with repeated elements."
msgstr "新创建的包含重复元素的 Series。"

#: maxframe.dataframe.misc.repeat.series_repeat of
msgid "返回类型"
msgstr ""

#: maxframe.dataframe.misc.repeat.series_repeat:19 of
msgid ":py:obj:`Index.repeat`"
msgstr ""

#: maxframe.dataframe.misc.repeat.series_repeat:20 of
msgid "Equivalent function for Index."
msgstr "Index 的等效函数。"

#: maxframe.dataframe.misc.repeat.series_repeat:22 of
msgid ":py:obj:`numpy.repeat`"
msgstr ""

#: maxframe.dataframe.misc.repeat.series_repeat:23 of
msgid "Similar method for :class:`numpy.ndarray`."
msgstr ":class:`numpy.ndarray` 的类似方法。"

