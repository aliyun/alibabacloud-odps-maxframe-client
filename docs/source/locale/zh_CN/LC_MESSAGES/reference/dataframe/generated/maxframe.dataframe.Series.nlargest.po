msgstr ""

#: maxframe.dataframe.sort.nlargest.series_nlargest:57 of
msgid "The `n` largest elements where ``n=5`` by default."
msgstr "默认情况下 ``n=5`` 时的最大的 `n` 个元素。"

#: maxframe.dataframe.sort.nlargest.series_nlargest:67 of
msgid ""
"The `n` largest elements where ``n=3``. Default `keep` value is 'first' "
"so Malta will be kept."
msgstr ""
"``n=3`` 时的最大的 `n` 个元素。默认的 `keep` 值为 'first'，因此 Malta 会"
"被保留。"

#: maxframe.dataframe.sort.nlargest.series_nlargest:76 of
msgid ""
