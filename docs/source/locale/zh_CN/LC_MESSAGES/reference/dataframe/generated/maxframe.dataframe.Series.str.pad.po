#: ../../source/reference/dataframe/generated/maxframe.dataframe.Series.str.pad.rst:2
msgid "maxframe.dataframe.Series.str.pad"
msgstr ""

#: of pandas.core.strings.accessor.StringMethods.pad:1
msgid "Pad strings in the Series/Index up to width."
msgstr "将 Series/Index 中的字符串填充到指定宽度。"

#: of pandas.core.strings.accessor.StringMethods.pad
msgid "参数"
msgstr ""

#: of pandas.core.strings.accessor.StringMethods.pad:3
msgid ""
"Minimum width of resulting string; additional characters will be filled "
"with character defined in `fillchar`."
msgstr "结果字符串的最小宽度；额外字符将使用 `fillchar` 中定义的字符进行填充。"

#: of pandas.core.strings.accessor.StringMethods.pad:6
msgid "Side from which to fill resulting string."
msgstr "用于填充结果字符串的一侧。"

#: of pandas.core.strings.accessor.StringMethods.pad:8
msgid "Additional character for filling, default is whitespace."
msgstr "用于填充的额外字符，默认为空格。"

#: of pandas.core.strings.accessor.StringMethods.pad
msgid "返回"
msgstr ""

#: of pandas.core.strings.accessor.StringMethods.pad:11
msgid "Returns Series or Index with minimum number of char in object."
msgstr "返回包含最少字符数的 Series 或 Index 对象。"

#: of pandas.core.strings.accessor.StringMethods.pad
msgid "返回类型"
msgstr ""

#: of pandas.core.strings.accessor.StringMethods.pad:16
msgid ":py:obj:`Series.str.rjust`"
msgstr ""

#: of pandas.core.strings.accessor.StringMethods.pad:17
msgid ""
"Fills the left side of strings with an arbitrary character. Equivalent to"
" ``Series.str.pad(side='left')``."
msgstr "用任意字符填充字符串的左侧。等效于 ``Series.str.pad(side='left')``。"

#: of pandas.core.strings.accessor.StringMethods.pad:19
msgid ":py:obj:`Series.str.ljust`"
msgstr ""

#: of pandas.core.strings.accessor.StringMethods.pad:20
msgid ""
"Fills the right side of strings with an arbitrary character. Equivalent "
"to ``Series.str.pad(side='right')``."
msgstr "用任意字符填充字符串的右侧。等效于 ``Series.str.pad(side='right')``。"

#: of pandas.core.strings.accessor.StringMethods.pad:22
msgid ":py:obj:`Series.str.center`"
msgstr ""

#: of pandas.core.strings.accessor.StringMethods.pad:23
msgid ""
"Fills both sides of strings with an arbitrary character. Equivalent to "
"``Series.str.pad(side='both')``."
msgstr "用任意字符填充字符串的两侧。等效于 ``Series.str.pad(side='both')``。"

#: of pandas.core.strings.accessor.StringMethods.pad:25
msgid ":py:obj:`Series.str.zfill`"
msgstr ""

#: of pandas.core.strings.accessor.StringMethods.pad:26
msgid ""
"Pad strings in the Series/Index by prepending '0' character. Equivalent "
"to ``Series.str.pad(side='left', fillchar='0')``."
msgstr ""
"通过在字符串前添加 '0' 字符来填充 Series/Index 中的字符串。等效于 ``"
"Series.str.pad(side='left', fillchar='0')``。"

