#: ../../source/reference/dataframe/generated/maxframe.dataframe.Series.str.len.rst:2
msgid "maxframe.dataframe.Series.str.len"
msgstr ""

#: of pandas.core.strings.accessor.StringMethods.len:1
msgid "Compute the length of each element in the Series/Index."
msgstr "计算 Series/Index 中每个元素的长度。"

#: of pandas.core.strings.accessor.StringMethods.len:3
msgid ""
"The element may be a sequence (such as a string, tuple or list) or a "
"collection (such as a dictionary)."
msgstr "元素可以是一个序列（如字符串、元组或列表）或一个集合（如字典）。"

#: of pandas.core.strings.accessor.StringMethods.len
msgid "返回"
msgstr ""

#: of pandas.core.strings.accessor.StringMethods.len:6
msgid ""
"A Series or Index of integer values indicating the length of each element"
" in the Series or Index."
msgstr "一个包含整数值的 Series 或 Index，表示 Series 或 Index 中每个元素的长度。"

#: of pandas.core.strings.accessor.StringMethods.len
msgid "返回类型"
msgstr ""

#: of pandas.core.strings.accessor.StringMethods.len:12
msgid ":py:obj:`str.len`"
msgstr ""

#: of pandas.core.strings.accessor.StringMethods.len:13
msgid "Python built-in function returning the length of an object."
msgstr "Python 内置函数，返回对象的长度。"

#: of pandas.core.strings.accessor.StringMethods.len:15
msgid ":py:obj:`Series.size`"
msgstr ""

#: of pandas.core.strings.accessor.StringMethods.len:16
msgid "Returns the length of the Series."
msgstr "返回 Series 的长度。"

#: of pandas.core.strings.accessor.StringMethods.len:19
msgid "示例"
msgstr ""

#: of pandas.core.strings.accessor.StringMethods.len:20
msgid ""
"Returns the length (number of characters) in a string. Returns the number"
" of entries for dictionaries, lists or tuples."
msgstr "返回字符串中的长度（字符数）。对于字典、列表或元组，返回其中条目的数量。"

