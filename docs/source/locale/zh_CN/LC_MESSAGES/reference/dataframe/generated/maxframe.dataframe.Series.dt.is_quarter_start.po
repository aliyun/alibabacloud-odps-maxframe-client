#: ../../source/reference/dataframe/generated/maxframe.dataframe.Series.dt.is_quarter_start.rst:2
msgid "maxframe.dataframe.Series.dt.is_quarter_start"
msgstr ""

#: ../../docstring maxframe.dataframe.Series.dt.is_quarter_start:1 of
msgid "Indicator for whether the date is the first day of a quarter."
msgstr "指示日期是否为季度的第一天。"

#: ../../docstring maxframe.dataframe.Series.dt.is_quarter_start of
msgid "返回"
msgstr ""

#: ../../docstring maxframe.dataframe.Series.dt.is_quarter_start:3 of
msgid ""
"**is_quarter_start** -- The same type as the original data with boolean "
"values. Series will have the same name and index. DatetimeIndex will have"
" the same name."
msgstr ""
"**is_quarter_start** -- 与原始数据类型相同，值为布尔类型。Series 将具有"
"相同的名称和索引。DatetimeIndex 将具有相同的名称。"

#: ../../docstring maxframe.dataframe.Series.dt.is_quarter_start of
msgid "返回类型"
msgstr ""

#: ../../docstring maxframe.dataframe.Series.dt.is_quarter_start:10 of
msgid ":py:obj:`quarter`"
msgstr ""

#: ../../docstring maxframe.dataframe.Series.dt.is_quarter_start:11 of
msgid "Return the quarter of the date."
msgstr "返回日期的季度。"

#: ../../docstring maxframe.dataframe.Series.dt.is_quarter_start:13 of
msgid ":py:obj:`is_quarter_end`"
msgstr ""

#: ../../docstring maxframe.dataframe.Series.dt.is_quarter_start:14 of
msgid "Similar property for indicating the quarter end."
msgstr "用于指示季度结束的类似属性。"

#: ../../docstring maxframe.dataframe.Series.dt.is_quarter_start:17 of
msgid "示例"
msgstr ""

#: ../../docstring maxframe.dataframe.Series.dt.is_quarter_start:18 of
msgid ""
"This method is available on Series with datetime values under the ``.dt``"
" accessor, and directly on DatetimeIndex."
msgstr ""
"此方法可用于包含 datetime 值的 Series（通过 ``.dt`` 访问器）以及直接用于 "
"DatetimeIndex。"

