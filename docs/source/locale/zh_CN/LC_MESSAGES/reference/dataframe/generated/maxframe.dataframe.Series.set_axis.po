#: maxframe.dataframe.indexing.set_axis.series_set_axis:1 of
msgid "Assign desired index to given axis."
msgstr "为给定轴分配所需的索引。"

#: maxframe.dataframe.indexing.set_axis.series_set_axis:3 of
msgid "Indexes for row labels can be changed by assigning a list-like or Index."
msgstr "可以通过分配一个类列表或 Index 对象来更改行标签的索引。"

#: maxframe.dataframe.indexing.set_axis.series_set_axis of
msgid "参数"
msgstr ""

#: maxframe.dataframe.indexing.set_axis.series_set_axis:6 of
msgid "The values for the new index."
msgstr "新索引的值。"

#: maxframe.dataframe.indexing.set_axis.series_set_axis:8 of
msgid "The axis to update. The value 0 identifies the rows."
msgstr "要更新的轴。值 0 表示行。"

#: maxframe.dataframe.indexing.set_axis.series_set_axis:10 of
msgid "Whether to return a new Series instance."
msgstr "是否返回一个新的 Series 实例。"

#: maxframe.dataframe.indexing.set_axis.series_set_axis of
msgid "返回"
msgstr ""

#: maxframe.dataframe.indexing.set_axis.series_set_axis:13 of
msgid "**renamed** -- An object of type Series or None if ``inplace=True``."
msgstr "**renamed** -- 类型为 Series 的对象，如果 ``inplace=True`` 则为 None。"

#: maxframe.dataframe.indexing.set_axis.series_set_axis of
msgid "返回类型"
msgstr ""

#: maxframe.dataframe.indexing.set_axis.series_set_axis:18 of
msgid ":py:obj:`Series.rename_axis`"
msgstr ""

#: maxframe.dataframe.indexing.set_axis.series_set_axis:19 of
msgid "Alter the name of the index."
msgstr "更改索引的名称。"

