#: ../../source/reference/dataframe/generated/maxframe.dataframe.Series.between_time.rst:2
msgid "maxframe.dataframe.Series.between\\_time"
msgstr ""

#: maxframe.dataframe.tseries.between_time.between_time:1 of
msgid "Select values between particular times of the day (e.g., 9:00-9:30 AM)."
msgstr "选择一天中特定时间之间的值（例如，上午9:00-9:30）。"

#: maxframe.dataframe.tseries.between_time.between_time:3 of
msgid ""
"By setting ``start_time`` to be later than ``end_time``, you can get the "
"times that are *not* between the two times."
msgstr ""
"通过将 ``start_time`` 设置为晚于 ``end_time``，您可以获取*不*在两个时间"
"之间的时段。"

#: maxframe.dataframe.tseries.between_time.between_time of
msgid "参数"
msgstr ""

#: maxframe.dataframe.tseries.between_time.between_time:6 of
msgid "Initial time as a time filter limit."
msgstr "作为时间过滤限制的初始时间。"

#: maxframe.dataframe.tseries.between_time.between_time:8 of
msgid "End time as a time filter limit."
msgstr "作为时间过滤限制的结束时间。"

#: maxframe.dataframe.tseries.between_time.between_time:10 of
msgid "Include boundaries; whether to set each bound as closed or open."
msgstr "包括边界；是否将每个边界设置为闭合或开放。"

#: maxframe.dataframe.tseries.between_time.between_time:12 of
msgid ""
"Determine range time on index or columns value. For `Series` this "
"parameter is unused and defaults to 0."
msgstr "确定索引或列值上的时间范围。对于 `Series` 此参数未使用，默认为 0。"

#: maxframe.dataframe.tseries.between_time.between_time of
msgid "返回"
msgstr ""

#: maxframe.dataframe.tseries.between_time.between_time:16 of
msgid "Data from the original object filtered to the specified dates range."
msgstr "从原始对象中筛选出指定日期范围内的数据。"

#: maxframe.dataframe.tseries.between_time.between_time of
msgid "返回类型"
msgstr ""

#: maxframe.dataframe.tseries.between_time.between_time of
msgid "抛出"
msgstr ""

#: maxframe.dataframe.tseries.between_time.between_time:19 of
msgid "If the index is not  a :class:`DatetimeIndex`"
msgstr "如果索引不是 :class:`DatetimeIndex`"

#: maxframe.dataframe.tseries.between_time.between_time:23 of
msgid ":py:obj:`at_time`"
msgstr ""

#: maxframe.dataframe.tseries.between_time.between_time:24 of
msgid "Select values at a particular time of the day."
msgstr "选择一天中特定时间的值。"

#: maxframe.dataframe.tseries.between_time.between_time:26 of
msgid ":py:obj:`first`"
msgstr ""

#: maxframe.dataframe.tseries.between_time.between_time:27 of
msgid "Select initial periods of time series based on a date offset."
msgstr "根据日期偏移量选择时间序列的初始时间段。"

#: maxframe.dataframe.tseries.between_time.between_time:29 of
msgid ":py:obj:`last`"
msgstr ""

#: maxframe.dataframe.tseries.between_time.between_time:30 of
msgid "Select final periods of time series based on a date offset."
msgstr "根据日期偏移量选择时间序列的最终时间段。"

#: maxframe.dataframe.tseries.between_time.between_time:32 of
msgid ":py:obj:`DatetimeIndex.indexer_between_time`"
msgstr ""

#: maxframe.dataframe.tseries.between_time.between_time:33 of
msgid ""
"Get just the index locations for values between particular times of the "
"day."
msgstr "仅获取一天中特定时间之间值的索引位置。"

#: maxframe.dataframe.tseries.between_time.between_time:36 of
msgid "示例"
msgstr ""

