msgid "maxframe.dataframe.DataFrame.nunique"
msgstr ""

#: maxframe.dataframe.reduction.nunique.nunique_dataframe:1 of
msgid "Count distinct observations over requested axis."
msgstr "统计指定轴上的不同观测值数量。"

#: maxframe.dataframe.reduction.nunique.nunique_dataframe:3 of
msgid "Return Series with number of distinct observations. Can ignore NaN values."
msgstr "返回包含不同观测值数量的 Series。可以忽略 NaN 值。"

#: maxframe.dataframe.reduction.nunique.nunique_dataframe of
msgid "参数"
msgstr ""

#: maxframe.dataframe.reduction.nunique.nunique_dataframe:6 of
msgid ""
"The axis to use. 0 or 'index' for row-wise, 1 or 'columns' for column-"
"wise."
msgstr "使用的轴。0 或 'index' 表示按行，1 或 'columns' 表示按列。"

#: maxframe.dataframe.reduction.nunique.nunique_dataframe:9 of
msgid "Don't include NaN in the counts."
msgstr "不在计数中包括 NaN。"

#: maxframe.dataframe.reduction.nunique.nunique_dataframe of
msgid "返回类型"
msgstr ""

#: maxframe.dataframe.reduction.nunique.nunique_dataframe:16 of
msgid ":py:obj:`Series.nunique`"
msgstr ""

#: maxframe.dataframe.reduction.nunique.nunique_dataframe:17 of
msgid "Method nunique for Series."
msgstr "Series 的 nunique 方法。"

#: maxframe.dataframe.reduction.nunique.nunique_dataframe:19 of
msgid ":py:obj:`DataFrame.count`"
msgstr ""

#: maxframe.dataframe.reduction.nunique.nunique_dataframe:20 of
msgid "Count non-NA cells for each column or row."
msgstr "统计每列或每行中非 NA 单元格的数量。"

