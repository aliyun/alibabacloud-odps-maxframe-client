#: ../../source/reference/dataframe/generated/maxframe.dataframe.Series.dict.__setitem__.rst:2
msgid "maxframe.dataframe.Series.dict.__setitem__"
msgstr ""

#: maxframe.dataframe.accessors.dict_.setitem.series_dict_setitem:1 of
msgid "Set the value with the key to each dict of the Series."
msgstr "将值与键一起设置到 Series 的每个字典中。"

#: maxframe.dataframe.accessors.dict_.setitem.series_dict_setitem of
msgid "参数"
msgstr ""

#: maxframe.dataframe.accessors.dict_.setitem.series_dict_setitem:3 of
msgid "The key of the value to set to, must be in the same key type of the dict."
msgstr "要设置的值的键，必须与字典中的键类型相同。"

#: maxframe.dataframe.accessors.dict_.setitem.series_dict_setitem:5 of
msgid ""
"The value to set, must be in the same value type of the dict. If the "
"``query_key`` exists, the value will be replaced. Otherwise, the value "
"will be added. A dict will be skipped if it's ``None``."
msgstr ""
"要设置的值，必须与字典中的值类型相同。如果 ``query_key`` 存在，则值将被"
"替换。否则，值将被添加。如果字典为 ``None``，则会被跳过。"

#: maxframe.dataframe.accessors.dict_.setitem.series_dict_setitem of
msgid "返回"
msgstr ""

#: maxframe.dataframe.accessors.dict_.setitem.series_dict_setitem:10 of
msgid "A Series with the same data type."
msgstr "一个具有相同数据类型的 Series。"

#: maxframe.dataframe.accessors.dict_.setitem.series_dict_setitem of
msgid "返回类型"
msgstr ""

#: maxframe.dataframe.accessors.dict_.setitem.series_dict_setitem:14 of
msgid "示例"
msgstr ""

#: maxframe.dataframe.accessors.dict_.setitem.series_dict_setitem:15 of
msgid "Create a series with dict type data."
msgstr "创建一个包含字典类型数据的 Series。"

