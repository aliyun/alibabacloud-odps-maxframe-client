#: ../../source/reference/tensor/generated/maxframe.tensor.exp2.rst:2
msgid "maxframe.tensor.exp2"
msgstr ""

#: maxframe.tensor.arithmetic.exp2.exp2:1 of
msgid "Calculate `2**p` for all `p` in the input tensor."
msgstr "计算输入张量中所有 `p` 的 `2**p`。"

#: maxframe.tensor.arithmetic.exp2.exp2 of
msgid "参数"
msgstr ""

#: maxframe.tensor.arithmetic.exp2.exp2:3 of
msgid "Input values."
msgstr "输入值。"

#: maxframe.tensor.arithmetic.exp2.exp2:5 of
msgid ""
"A location into which the result is stored. If provided, it must have a "
"shape that the inputs broadcast to. If not provided or `None`, a freshly-"
"allocated tensor is returned. A tuple (possible only as a keyword "
"argument) must have length equal to the number of outputs."
msgstr ""
"用于存储结果的位置。如果提供，其形状必须可以广播到输入形状。如果未提供或"
"为 `None`，则返回一个新分配的张量。元组（只能作为关键字参数）的长度必须"
"等于输出数量。"

#: maxframe.tensor.arithmetic.exp2.exp2:10 of
msgid ""
"Values of True indicate to calculate the ufunc at that position, values "
"of False indicate to leave the value in the output alone."
msgstr "值为 True 表示在该位置计算 ufunc，值为 False 表示保留输出中的值不变。"

#: maxframe.tensor.arithmetic.exp2.exp2 of
msgid "返回"
msgstr ""

#: maxframe.tensor.arithmetic.exp2.exp2:15 of
msgid "**out** -- Element-wise 2 to the power `x`."
msgstr "**out** -- 元素级的 2 的 `x` 次幂。"

#: maxframe.tensor.arithmetic.exp2.exp2 of
msgid "返回类型"
msgstr ""

#: maxframe.tensor.arithmetic.exp2.exp2:18 of
msgid ":py:obj:`power`"
msgstr ""

