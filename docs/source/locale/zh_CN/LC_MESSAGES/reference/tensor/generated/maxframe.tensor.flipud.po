#: ../../source/reference/tensor/generated/maxframe.tensor.flipud.rst:2
msgid "maxframe.tensor.flipud"
msgstr ""

#: maxframe.tensor.misc.flipud.flipud:1 of
msgid "Flip tensor in the up/down direction."
msgstr "沿上下方向翻转张量。"

#: maxframe.tensor.misc.flipud.flipud:3 of
msgid ""
"Flip the entries in each column in the up/down direction. Rows are "
"preserved, but appear in a different order than before."
msgstr "沿上下方向翻转每列中的元素。行保持不变，但顺序与之前不同。"

#: maxframe.tensor.misc.flipud.flipud of
msgid "参数"
msgstr ""

#: maxframe.tensor.misc.flipud.flipud:6 of
msgid "Input tensor."
msgstr "输入张量。"

#: maxframe.tensor.misc.flipud.flipud of
msgid "返回"
msgstr ""

#: maxframe.tensor.misc.flipud.flipud:9 of
msgid ""
"**out** -- A view of `m` with the rows reversed.  Since a view is "
"returned, this operation is :math:`\\mathcal O(1)`."
msgstr ""
"**out** -- 一个行顺序反转的 `m` 视图。由于返回的是视图，此操作的时间"
"复杂度为 :math:`\\mathcal O(1)`。"

#: maxframe.tensor.misc.flipud.flipud of
msgid "返回类型"
msgstr ""

#: maxframe.tensor.misc.flipud.flipud:15 of
msgid ":py:obj:`fliplr`"
msgstr ""

#: maxframe.tensor.misc.flipud.flipud:16 of
msgid "Flip tensor in the left/right direction."
msgstr "沿左右方向翻转张量。"

#: maxframe.tensor.misc.flipud.flipud:18 of
msgid ":py:obj:`rot90`"
msgstr ""

#: maxframe.tensor.misc.flipud.flipud:19 of
msgid "Rotate tensor counterclockwise."
msgstr "逆时针旋转张量。"

#: maxframe.tensor.misc.flipud.flipud:22 of
msgid "备注"
msgstr ""

#: maxframe.tensor.misc.flipud.flipud:23 of
msgid ""
"Equivalent to ``m[::-1,...]``. Does not require the tensor to be two-"
"dimensional."
msgstr "等价于 ``m[::-1,...]``。不要求张量必须是二维的。"

