#: ../../source/reference/tensor/generated/maxframe.tensor.nextafter.rst:2
msgid "maxframe.tensor.nextafter"
msgstr ""

#: maxframe.tensor.arithmetic.nextafter.nextafter:1 of
msgid "Return the next floating-point value after x1 towards x2, element-wise."
msgstr "返回 x1 朝 x2 方向的下一个浮点值，逐元素。"

#: maxframe.tensor.arithmetic.nextafter.nextafter of
msgid "参数"
msgstr ""

#: maxframe.tensor.arithmetic.nextafter.nextafter:3 of
msgid "Values to find the next representable value of."
msgstr "要查找其下一个可表示值的值。"

#: maxframe.tensor.arithmetic.nextafter.nextafter:5 of
msgid "The direction where to look for the next representable value of `x1`."
msgstr "查找 `x1` 的下一个可表示值的方向。"

#: maxframe.tensor.arithmetic.nextafter.nextafter:7 of
msgid ""
"A location into which the result is stored. If provided, it must have a "
"shape that the inputs broadcast to. If not provided or `None`, a freshly-"
"allocated tensor is returned. A tuple (possible only as a keyword "
"argument) must have length equal to the number of outputs."
msgstr ""
"用于存储结果的位置。如果提供，其形状必须与输入广播兼容。如果未提供或为 `"
"None`，则返回一个新分配的 tensor。元组（只能作为关键字参数）的长度必须"
"等于输出的数量。"

#: maxframe.tensor.arithmetic.nextafter.nextafter:12 of
msgid ""
"Values of True indicate to calculate the ufunc at that position, values "
"of False indicate to leave the value in the output alone."
msgstr "值为 True 表示在该位置计算 ufunc，值为 False 表示保留输出中的值不变。"

#: maxframe.tensor.arithmetic.nextafter.nextafter of
msgid "返回"
msgstr ""

#: maxframe.tensor.arithmetic.nextafter.nextafter:17 of
msgid "**out** -- The next representable values of `x1` in the direction of `x2`."
msgstr "**out** -- `x1` 在 `x2` 方向上的下一个可表示值。"

#: maxframe.tensor.arithmetic.nextafter.nextafter of
msgid "返回类型"
msgstr ""

