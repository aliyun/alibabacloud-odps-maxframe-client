#: ../../source/reference/tensor/generated/maxframe.tensor.flatnonzero.rst:2
msgid "maxframe.tensor.flatnonzero"
msgstr ""

#: maxframe.tensor.indexing.flatnonzero.flatnonzero:1 of
msgid "Return indices that are non-zero in the flattened version of a."
msgstr "返回在 a 的展平版本中非零元素的索引。"

#: maxframe.tensor.indexing.flatnonzero.flatnonzero:3 of
msgid "This is equivalent to a.ravel().nonzero()[0]."
msgstr "这等价于 a.ravel().nonzero()[0]。"

#: maxframe.tensor.indexing.flatnonzero.flatnonzero of
msgid "参数"
msgstr ""

#: maxframe.tensor.indexing.flatnonzero.flatnonzero:5 of
msgid "Input tensor."
msgstr "输入张量。"

#: maxframe.tensor.indexing.flatnonzero.flatnonzero of
msgid "返回"
msgstr ""

#: maxframe.tensor.indexing.flatnonzero.flatnonzero:8 of
msgid ""
"**res** -- Output tensor, containing the indices of the elements of "
"`a.ravel()` that are non-zero."
msgstr "**res** -- 输出张量，包含 `a.ravel()` 中非零元素的索引。"

#: maxframe.tensor.indexing.flatnonzero.flatnonzero of
msgid "返回类型"
msgstr ""

#: maxframe.tensor.indexing.flatnonzero.flatnonzero:14 of
msgid ":py:obj:`nonzero`"
msgstr ""

#: maxframe.tensor.indexing.flatnonzero.flatnonzero:15 of
msgid "Return the indices of the non-zero elements of the input tensor."
msgstr "返回输入张量中非零元素的索引。"

#: maxframe.tensor.indexing.flatnonzero.flatnonzero:17 of
msgid ":py:obj:`ravel`"
msgstr ""

#: maxframe.tensor.indexing.flatnonzero.flatnonzero:18 of
msgid "Return a 1-D tensor containing the elements of the input tensor."
msgstr "返回包含输入张量元素的一维张量。"

#: maxframe.tensor.indexing.flatnonzero.flatnonzero:21 of
msgid "示例"
msgstr ""

#: maxframe.tensor.indexing.flatnonzero.flatnonzero:30 of
msgid ""
"Use the indices of the non-zero elements as an index array to extract "
"these elements:"
msgstr "使用非零元素的索引作为索引数组来提取这些元素："

