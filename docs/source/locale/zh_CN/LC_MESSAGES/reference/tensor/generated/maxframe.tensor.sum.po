#: ../../source/reference/tensor/generated/maxframe.tensor.sum.rst:2
msgid "maxframe.tensor.sum"
msgstr ""

#: maxframe.tensor.reduction.sum.sum:1 of
msgid "Sum of tensor elements over a given axis."
msgstr "沿给定轴对张量元素求和。"

#: maxframe.tensor.reduction.sum.sum of
msgid "参数"
msgstr ""

#: maxframe.tensor.reduction.sum.sum:3 of
msgid "Elements to sum."
msgstr "要求和的元素。"

#: maxframe.tensor.reduction.sum.sum:5 of
msgid ""
"Axis or axes along which a sum is performed.  The default, axis=None, "
"will sum all of the elements of the input tensor.  If axis is negative it"
" counts from the last to the first axis.  If axis is a tuple of ints, a "
"sum is performed on all of the axes specified in the tuple instead of a "
"single axis or all the axes as before."
msgstr ""
"执行求和操作的轴。默认值 axis=None 将对输入张量的所有元素求和。如果 axis "
"是负数，则从最后一个轴开始计数。如果 axis 是一个整数元组，则对元组中指定"
"的所有轴执行求和操作，而不是单个轴或所有轴。"

#: maxframe.tensor.reduction.sum.sum:5 of
#, fuzzy
msgid ""
"Axis or axes along which a sum is performed.  The default, axis=None, "
"will sum all of the elements of the input tensor.  If axis is negative it"
