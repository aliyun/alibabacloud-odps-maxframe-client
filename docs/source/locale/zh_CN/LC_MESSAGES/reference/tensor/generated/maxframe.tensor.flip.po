#: ../../source/reference/tensor/generated/maxframe.tensor.flip.rst:2
msgid "maxframe.tensor.flip"
msgstr ""

#: maxframe.tensor.misc.flip.flip:1 of
msgid "Reverse the order of elements in a tensor along the given axis."
msgstr "沿给定轴反转张量中元素的顺序。"

#: maxframe.tensor.misc.flip.flip:3 of
msgid "The shape of the array is preserved, but the elements are reordered."
msgstr "数组的形状保持不变，但元素会被重新排序。"

#: maxframe.tensor.misc.flip.flip of
msgid "参数"
msgstr ""

#: maxframe.tensor.misc.flip.flip:5 of
msgid "Input tensor."
msgstr "输入张量。"

#: maxframe.tensor.misc.flip.flip:7 of
msgid "Axis in tensor, which entries are reversed."
msgstr "张量中要反转条目的轴。"

#: maxframe.tensor.misc.flip.flip of
msgid "返回"
msgstr ""

#: maxframe.tensor.misc.flip.flip:10 of
msgid ""
"**out** -- A view of `m` with the entries of axis reversed.  Since a view"
" is returned, this operation is done in constant time."
msgstr ""
"**out** -- 一个 `m` 的视图，其轴上的条目被反转。由于返回的是视图，此操作"
"在常量时间内完成。"

#: maxframe.tensor.misc.flip.flip of
msgid "返回类型"
msgstr ""

#: maxframe.tensor.misc.flip.flip:16 of
msgid ":py:obj:`flipud`"
msgstr ""

#: maxframe.tensor.misc.flip.flip:17 of
msgid "Flip a tensor vertically (axis=0)."
msgstr "垂直翻转张量（axis=0）。"

#: maxframe.tensor.misc.flip.flip:19 of
msgid ":py:obj:`fliplr`"
msgstr ""

#: maxframe.tensor.misc.flip.flip:20 of
msgid "Flip a tensor horizontally (axis=1)."
msgstr "水平翻转张量（axis=1）。"

#: maxframe.tensor.misc.flip.flip:23 of
msgid "备注"
msgstr ""

#: maxframe.tensor.misc.flip.flip:24 of
msgid ""
"flip(m, 0) is equivalent to flipud(m). flip(m, 1) is equivalent to "
"fliplr(m). flip(m, n) corresponds to ``m[...,::-1,...]`` with ``::-1`` at"
" position n."
msgstr ""
"flip(m, 0) 等价于 flipud(m)。flip(m, 1) 等价于 fliplr(m)。flip(m, n) 对应"
"于 ``m[...,::-1,...]``，其中 ``::-1`` 位于第 n 个位置。"

#: maxframe.tensor.misc.flip.flip:29 of
msgid "示例"
msgstr ""

#: maxframe.tensor.misc.flip.flip:37 of
msgid "[[4, 5],"
msgstr ""

#: maxframe.tensor.misc.flip.flip:38 of
msgid "[6, 7]]])"
msgstr ""

#: maxframe.tensor.misc.flip.flip:44 of
msgid "[[0, 1],"
msgstr ""

#: maxframe.tensor.misc.flip.flip:45 of
msgid "[2, 3]]])"
msgstr ""

#: maxframe.tensor.misc.flip.flip:51 of
msgid "[[6, 7],"
msgstr ""

#: maxframe.tensor.misc.flip.flip:52 of
msgid "[4, 5]]])"
msgstr ""

