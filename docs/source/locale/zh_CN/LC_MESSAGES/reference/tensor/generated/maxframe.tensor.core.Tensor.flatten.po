#: ../../source/reference/tensor/generated/maxframe.tensor.core.Tensor.flatten.rst:2
msgid "maxframe.tensor.core.Tensor.flatten"
msgstr ""

#: maxframe.tensor.misc.flatten.flatten:1 of
msgid "Return a copy of the tensor collapsed into one dimension."
msgstr "返回一个折叠成一维的张量副本。"

#: maxframe.tensor.misc.flatten.flatten of
msgid "参数"
msgstr ""

#: maxframe.tensor.misc.flatten.flatten:3 of
msgid ""
"'C' means to flatten in row-major (C-style) order. 'F' means to flatten "
"in column-major (Fortran- style) order. 'A' means to flatten in column-"
"major order if `a` is Fortran *contiguous* in memory, row-major order "
"otherwise. 'K' means to flatten `a` in the order the elements occur in "
"memory. The default is 'C'."
msgstr ""
"'C' 表示按行主序（C 风格）展开。'F' 表示按列主序（Fortran 风格）展开。"
"如果 `a` 在内存中是 Fortran *连续* 的，则 'A' 表示按列主序展开，否则按行"
"主序展开。'K' 表示按元素在内存中的顺序展开。默认值为 'C'。"

#: maxframe.tensor.misc.flatten.flatten of
msgid "返回"
msgstr ""

#: maxframe.tensor.misc.flatten.flatten:12 of
msgid "**y** -- A copy of the input tensor, flattened to one dimension."
msgstr "**y** -- 输入张量的一个副本，被展平为一维。"

#: maxframe.tensor.misc.flatten.flatten of
msgid "返回类型"
msgstr ""

#: maxframe.tensor.misc.flatten.flatten:17 of
msgid ":py:obj:`ravel`"
msgstr ""

#: maxframe.tensor.misc.flatten.flatten:18 of
msgid "Return a flattened tensor."
msgstr "返回一个展平的张量。"

#: maxframe.tensor.misc.flatten.flatten:20 of
msgid ":py:obj:`flat`"
msgstr ""

#: maxframe.tensor.misc.flatten.flatten:21 of
msgid "A 1-D flat iterator over the tensor."
msgstr "一个张量上的一维平坦迭代器。"

#: maxframe.tensor.misc.flatten.flatten:24 of
msgid "示例"
msgstr ""

