#: ../../source/reference/tensor/generated/maxframe.tensor.special.softplus.rst:2
msgid "maxframe.tensor.special.softplus"
msgstr ""

#: maxframe.tensor.special.misc.softplus:1 of
msgid "Compute the softplus function element-wise."
msgstr "逐元素计算 softplus 函数。"

#: maxframe.tensor.special.misc.softplus:3 of
msgid ""
"The softplus function is defined as: ``softplus(x) = log(1 + exp(x))``. "
"It is a smooth approximation of the rectifier function (ReLU)."
msgstr ""
"softplus 函数定义为：``softplus(x) = log(1 + exp(x))``。它是修正线性单元"
"（ReLU）函数的平滑近似。"

#: maxframe.tensor.special.misc.softplus of
msgid "参数"
msgstr ""

#: maxframe.tensor.special.misc.softplus:6 of
msgid "Input value."
msgstr "输入值。"

#: maxframe.tensor.special.misc.softplus:8 of
msgid ""
"For other keyword-only arguments, see the `ufunc docs "
"<https://numpy.org/doc/stable/reference/ufuncs.html>`_."
msgstr ""
"对于其他仅关键字参数，请参见 `ufunc 文档 <https://numpy.org/doc/stable/"
"reference/ufuncs.html>`_。"

#: maxframe.tensor.special.misc.softplus of
msgid "返回"
msgstr ""

#: maxframe.tensor.special.misc.softplus:11 of
msgid "**softplus** -- Logarithm of ``exp(0) + exp(x)``."
msgstr "**softplus** -- ``exp(0) + exp(x)`` 的对数。"

#: maxframe.tensor.special.misc.softplus of
msgid "返回类型"
msgstr ""

