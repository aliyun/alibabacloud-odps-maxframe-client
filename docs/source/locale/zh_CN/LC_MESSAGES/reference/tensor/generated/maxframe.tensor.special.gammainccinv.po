msgid "Positive parameter"
msgstr "正参数"

#: maxframe.tensor.special.gamma_funcs.gammainccinv:11 of
msgid "Argument between 0 and 1, inclusive"
msgstr "介于 0 和 1 之间的参数，包含边界值"

#: maxframe.tensor.special.gamma_funcs.gammainccinv:13 of
msgid "Optional output array for the function values"
msgstr "可选的输出数组，用于存储函数值"

#: ../../source/reference/tensor/generated/maxframe.tensor.special.gammainccinv.rst
msgid "返回"
msgstr ""

#: maxframe.tensor.special.gamma_funcs.gammainccinv:16 of
msgid "Values of the inverse of the upper incomplete gamma function"
msgstr "上不完全伽马函数的反函数值"

#: ../../source/reference/tensor/generated/maxframe.tensor.special.gammainccinv.rst
msgid "返回类型"
msgstr ""

