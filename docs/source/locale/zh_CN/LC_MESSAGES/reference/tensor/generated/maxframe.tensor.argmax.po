#: ../../source/reference/tensor/generated/maxframe.tensor.argmax.rst:2
msgid "maxframe.tensor.argmax"
msgstr ""

#: maxframe.tensor.reduction.argmax.argmax:1 of
msgid "Returns the indices of the maximum values along an axis."
msgstr "返回沿轴的最大值的索引。"

#: maxframe.tensor.reduction.argmax.argmax of
msgid "参数"
msgstr ""

#: maxframe.tensor.reduction.argmax.argmax:3 of
msgid "Input tensor."
msgstr "输入张量。"

#: maxframe.tensor.reduction.argmax.argmax:5 of
msgid ""
"By default, the index is into the flattened tensor, otherwise along the "
"specified axis."
msgstr "默认情况下，索引是展平张量中的索引，否则沿指定轴。"

#: maxframe.tensor.reduction.argmax.argmax:8 of
msgid ""
"If provided, the result will be inserted into this tensor. It should be "
"of the appropriate shape and dtype."
msgstr "如果提供，则结果将插入到此张量中。它应具有适当的形状和数据类型。"

#: maxframe.tensor.reduction.argmax.argmax of
msgid "返回"
msgstr ""

#: maxframe.tensor.reduction.argmax.argmax:12 of
msgid ""
"**index_array** -- Tensor of indices into the tensor. It has the same "
"shape as `a.shape` with the dimension along `axis` removed."
msgstr ""
"**index_array** -- 张量中索引的张量。它与 `a.shape` 具有相同的形状，但沿 "
"`axis` 的维度被移除。"

#: maxframe.tensor.reduction.argmax.argmax of
msgid "返回类型"
msgstr ""

#: maxframe.tensor.reduction.argmax.argmax:18 of
msgid ":py:obj:`Tensor.argmax`, :py:obj:`argmin`"
msgstr ""

#: maxframe.tensor.reduction.argmax.argmax:20 of
msgid ":py:obj:`amax`"
msgstr ""

#: maxframe.tensor.reduction.argmax.argmax:21 of
msgid "The maximum value along a given axis."
msgstr "沿给定轴的最大值。"

#: maxframe.tensor.reduction.argmax.argmax:23 of
msgid ":py:obj:`unravel_index`"
msgstr ""

#: maxframe.tensor.reduction.argmax.argmax:24 of
msgid "Convert a flat index into an index tuple."
msgstr "将平面索引转换为索引元组。"

#: maxframe.tensor.reduction.argmax.argmax:27 of
msgid "备注"
msgstr ""

#: maxframe.tensor.reduction.argmax.argmax:28 of
msgid ""
"In case of multiple occurrences of the maximum values, the indices "
"corresponding to the first occurrence are returned."
msgstr "在最大值多次出现的情况下，返回对应于第一次出现的索引。"

#: maxframe.tensor.reduction.argmax.argmax:32 of
msgid "示例"
msgstr ""

#: maxframe.tensor.reduction.argmax.argmax:46 of
msgid "Indexes of the maximal elements of a N-dimensional tensor:"
msgstr "N维张量的最大元素的索引："

