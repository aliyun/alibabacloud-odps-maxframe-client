#: ../../source/reference/tensor/generated/maxframe.tensor.special.betaincinv.rst:2
msgid "maxframe.tensor.special.betaincinv"
msgstr ""

#: maxframe.tensor.special.gamma_funcs.betaincinv:1 of
msgid "Inverse of the regularized incomplete beta function."
msgstr "正则化不完全贝塔函数的反函数。"

#: maxframe.tensor.special.gamma_funcs.betaincinv:3 of
msgid "Computes :math:`x` such that:"
msgstr "计算满足以下条件的 :math:`x`："

#: maxframe.tensor.special.gamma_funcs.betaincinv:5 of
#, python-brace-format
msgid ""
"y = I_x(a, b) = \\frac{\\Gamma(a+b)}{\\Gamma(a)\\Gamma(b)}\n"
"\\int_0^x t^{a-1}(1-t)^{b-1}dt,"
msgstr ""

#: maxframe.tensor.special.gamma_funcs.betaincinv:10 of
msgid ""
"where :math:`I_x` is the normalized incomplete beta function `betainc` "
"and :math:`\\Gamma` is the `gamma` function [1]_."
msgstr ""
"其中 :math:`I_x` 是归一化的不完全贝塔函数 `betainc`，:math:`\\Gamma` 是 `"
"gamma` 函数 [1]_。"

#: ../../source/reference/tensor/generated/maxframe.tensor.special.betaincinv.rst
msgid "参数"
msgstr ""

#: maxframe.tensor.special.gamma_funcs.betaincinv:13
#: maxframe.tensor.special.gamma_funcs.betaincinv:15 of
msgid "Positive, real-valued parameters"
msgstr "正实数参数"

#: maxframe.tensor.special.gamma_funcs.betaincinv:17 of
msgid "Real-valued input"
msgstr "实数输入"

#: maxframe.tensor.special.gamma_funcs.betaincinv:19 of
msgid "Optional output array for function values"
msgstr "可选的函数值输出数组"

#: ../../source/reference/tensor/generated/maxframe.tensor.special.betaincinv.rst
msgid "返回"
msgstr ""

#: maxframe.tensor.special.gamma_funcs.betaincinv:22 of
msgid "Value of the inverse of the regularized incomplete beta function"
msgstr "正则化不完全贝塔函数的反函数值"

#: ../../source/reference/tensor/generated/maxframe.tensor.special.betaincinv.rst
msgid "返回类型"
msgstr ""

#: maxframe.tensor.special.gamma_funcs.betaincinv:27 of
msgid ":py:obj:`betainc`"
msgstr ""

#: maxframe.tensor.special.gamma_funcs.betaincinv:28 of
msgid "regularized incomplete beta function"
msgstr "正则化不完全贝塔函数"

#: maxframe.tensor.special.gamma_funcs.betaincinv:30 of
msgid ":py:obj:`gamma`"
msgstr ""

#: maxframe.tensor.special.gamma_funcs.betaincinv:31 of
msgid "gamma function"
msgstr "伽玛函数"

#: maxframe.tensor.special.gamma_funcs.betaincinv:34 of
msgid "备注"
msgstr ""

#: maxframe.tensor.special.gamma_funcs.betaincinv:35 of
msgid ""
"This function wraps the ``ibeta_inv`` routine from the Boost Math C++ "
"library [2]_."
msgstr "该函数封装了 Boost Math C++ 库中的 ``ibeta_inv`` 例程 [2]_。"

