#: ../../source/reference/tensor/generated/maxframe.tensor.special.erf.rst:2
msgid "maxframe.tensor.special.erf"
msgstr ""

#: maxframe.tensor.special.err_fresnel.erf:1 of
msgid "Returns the error function of complex argument."
msgstr "返回复数参数的误差函数。"

#: maxframe.tensor.special.err_fresnel.erf:3 of
msgid "It is defined as ``2/sqrt(pi)*integral(exp(-t**2), t=0..z)``."
msgstr "其定义为 ``2/sqrt(pi)*integral(exp(-t**2), t=0..z)``。"

#: maxframe.tensor.special.err_fresnel.erf of
msgid "参数"
msgstr ""

#: maxframe.tensor.special.err_fresnel.erf:5 of
msgid "Input tensor."
msgstr "输入张量。"

#: maxframe.tensor.special.err_fresnel.erf of
msgid "返回"
msgstr ""

#: maxframe.tensor.special.err_fresnel.erf:8 of
msgid "**res** -- The values of the error function at the given points `x`."
msgstr "**res** -- 给定点 `x` 处的误差函数值。"

#: maxframe.tensor.special.err_fresnel.erf of
msgid "返回类型"
msgstr ""

#: maxframe.tensor.special.err_fresnel.erf:11 of
msgid ""
":py:obj:`erfc`, :py:obj:`erfinv`, :py:obj:`erfcinv`, :py:obj:`wofz`, "
":py:obj:`erfcx`, :py:obj:`erfi`"
msgstr ""

#: maxframe.tensor.special.err_fresnel.erf:14 of
msgid "备注"
msgstr ""

#: maxframe.tensor.special.err_fresnel.erf:15 of
msgid ""
"The cumulative of the unit normal distribution is given by ``Phi(z) = "
"1/2[1 + erf(z/sqrt(2))]``."
msgstr "标准正态分布的累积分布函数由 ``Phi(z) = 1/2[1 + erf(z/sqrt(2))]`` 给出。"

