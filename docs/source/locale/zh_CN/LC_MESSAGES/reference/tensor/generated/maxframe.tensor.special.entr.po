#: maxframe.tensor.special.info_theory.entr:1 of
msgid "Elementwise function for computing entropy."
msgstr "用于计算熵的逐元素函数。"

#: maxframe.tensor.special.info_theory.entr:3 of
#, python-brace-format
msgid ""
"\\text{entr}(x) = \\begin{cases} - x \\log(x) & x > 0  \\\\ 0 & x = 0 "
"\\\\ -\\infty & \\text{otherwise} \\end{cases}\n"
"\n"
msgstr ""

