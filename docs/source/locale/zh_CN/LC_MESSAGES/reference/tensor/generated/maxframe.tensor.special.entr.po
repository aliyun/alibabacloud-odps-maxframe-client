msgstr "输入张量。"

#: maxframe.tensor.special.info_theory.entr of
msgid "返回"
msgstr ""

#: maxframe.tensor.special.info_theory.entr:8 of
msgid ""
"**res** -- The value of the elementwise entropy function at the given "
"points `x`."
msgstr "**res** -- 在给定点 `x` 处逐元素熵函数的值。"

#: maxframe.tensor.special.info_theory.entr of
msgid "返回类型"
msgstr ""

#: maxframe.tensor.special.info_theory.entr:11 of
