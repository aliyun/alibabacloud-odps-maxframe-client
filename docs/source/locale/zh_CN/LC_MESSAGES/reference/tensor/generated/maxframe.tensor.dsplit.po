#: ../../source/reference/tensor/generated/maxframe.tensor.dsplit.rst:2
msgid "maxframe.tensor.dsplit"
msgstr ""

#: maxframe.tensor.misc.dsplit.dsplit:1 of
msgid "Split tensor into multiple sub-tensors along the 3rd axis (depth)."
msgstr "沿第3轴（深度）将张量分割为多个子张量。"

#: maxframe.tensor.misc.dsplit.dsplit:3 of
msgid ""
"Please refer to the `split` documentation.  `dsplit` is equivalent to "
"`split` with ``axis=2``, the array is always split along the third axis "
"provided the tensor dimension is greater than or equal to 3."
msgstr ""
"请参考 `split` 文档。`dsplit` 等价于 ``axis=2`` 的 `split`，只要张量维度"
"大于或等于3，数组总是沿第三个轴进行分割。"

#: maxframe.tensor.misc.dsplit.dsplit:9 of
msgid ":py:obj:`split`"
msgstr ""

#: maxframe.tensor.misc.dsplit.dsplit:10 of
msgid "Split a tensor into multiple sub-arrays of equal size."
msgstr "将张量分割为多个大小相等的子数组。"

