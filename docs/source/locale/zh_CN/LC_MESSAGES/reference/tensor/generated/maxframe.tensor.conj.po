#: ../../source/reference/tensor/generated/maxframe.tensor.conj.rst:2
msgid "maxframe.tensor.conj"
msgstr ""

#: maxframe.tensor.arithmetic.conj.conj:1 of
msgid "Return the complex conjugate, element-wise."
msgstr "逐元素返回复数的共轭。"

#: maxframe.tensor.arithmetic.conj.conj:3 of
msgid ""
"The complex conjugate of a complex number is obtained by changing the "
"sign of its imaginary part."
msgstr "复数的共轭是通过改变其虚部的符号得到的。"

#: maxframe.tensor.arithmetic.conj.conj of
msgid "参数"
msgstr ""

#: maxframe.tensor.arithmetic.conj.conj:6 of
msgid "Input value."
msgstr "输入值。"

#: maxframe.tensor.arithmetic.conj.conj:8 of
msgid ""
"A location into which the result is stored. If provided, it must have a "
"shape that the inputs broadcast to. If not provided or `None`, a freshly-"
"allocated tensor is returned. A tuple (possible only as a keyword "
"argument) must have length equal to the number of outputs."
msgstr ""
"存储结果的位置。如果提供，其形状必须可以广播到输入形状。如果未提供或为 `"
"None`，则返回一个新分配的张量。元组（只能作为关键字参数）的长度必须等于"
"输出的数量。"

#: maxframe.tensor.arithmetic.conj.conj:13 of
msgid ""
"Values of True indicate to calculate the ufunc at that position, values "
"of False indicate to leave the value in the output alone."
msgstr "值为 True 表示在该位置计算 ufunc，值为 False 表示保留输出中的值不变。"

#: maxframe.tensor.arithmetic.conj.conj of
msgid "返回"
msgstr ""

#: maxframe.tensor.arithmetic.conj.conj:18 of
msgid "**y** -- The complex conjugate of `x`, with same dtype as `y`."
msgstr "**y** -- `x` 的复数共轭，与 `y` 具有相同的 dtype。"

#: maxframe.tensor.arithmetic.conj.conj of
msgid "返回类型"
msgstr ""

