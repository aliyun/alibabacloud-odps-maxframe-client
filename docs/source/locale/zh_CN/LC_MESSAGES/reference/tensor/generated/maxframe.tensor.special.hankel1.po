#: maxframe.tensor.special.bessel.hankel1:20 of
msgid ""
"A wrapper for the AMOS [1]_ routine `zbesh`, which carries out the "
"computation using the relation,"
msgstr "对 AMOS [1]_ 例程 `zbesh` 的封装，该例程使用以下关系进行计算，"

#: maxframe.tensor.special.bessel.hankel1:23 of
#, python-brace-format
msgid ""
"H^{(1)}_v(z) =\n"
"\\frac{2}{\\imath\\pi} \\exp(-\\imath \\pi v/2) K_v(z "
"\\exp(-\\imath\\pi/2))\n"
"\n"
msgstr ""

#: maxframe.tensor.special.bessel.hankel1:26 of
msgid ""
"where :math:`K_v` is the modified Bessel function of the second kind. For"
" negative orders, the relation"
msgstr "其中 :math:`K_v` 是第二类变形贝塞尔函数。对于负阶数，使用以下关系"

#: maxframe.tensor.special.bessel.hankel1:29 of
#, python-brace-format
msgid ""
"H^{(1)}_{-v}(z) = H^{(1)}_v(z) \\exp(\\imath\\pi v)\n"
"\n"
msgstr ""

#: maxframe.tensor.special.bessel.hankel1:31 of
msgid "is used."
msgstr "进行计算。"

#: maxframe.tensor.special.bessel.hankel1:34 of
msgid "引用"
msgstr ""

#: maxframe.tensor.special.bessel.hankel1:35 of
msgid ""
"Donald E. Amos, \"AMOS, A Portable Package for Bessel Functions of a "
"Complex Argument and Nonnegative Order\", http://netlib.org/amos/"
msgstr ""

