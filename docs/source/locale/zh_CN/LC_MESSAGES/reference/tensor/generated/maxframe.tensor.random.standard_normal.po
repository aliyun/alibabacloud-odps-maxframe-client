#: ../../source/reference/tensor/generated/maxframe.tensor.random.standard_normal.rst:2
msgid "maxframe.tensor.random.standard\\_normal"
msgstr ""

#: maxframe.tensor.random.standard_normal.standard_normal:1 of
msgid "Draw samples from a standard Normal distribution (mean=0, stdev=1)."
msgstr "从标准正态分布（均值=0，标准差=1）中抽取样本。"

#: maxframe.tensor.random.standard_normal.standard_normal of
msgid "参数"
msgstr ""

#: maxframe.tensor.random.standard_normal.standard_normal:3 of
msgid ""
"Output shape.  If the given shape is, e.g., ``(m, n, k)``, then ``m * n *"
" k`` samples are drawn.  Default is None, in which case a single value is"
" returned."
msgstr ""
"输出形状。如果给定的形状是，例如 ``(m, n, k)``，那么将抽取 ``m * n * k`` "
"个样本。默认为 None，此时返回单个值。"

#: maxframe.tensor.random.standard_normal.standard_normal:7 of
msgid "Desired chunk size on each dimension"
msgstr "每个维度上期望的块大小"

#: maxframe.tensor.random.standard_normal.standard_normal:9 of
msgid "Allocate the tensor on GPU if True, False as default"
msgstr "如果为 True，则在 GPU 上分配张量，默认为 False"

#: maxframe.tensor.random.standard_normal.standard_normal:11 of
msgid "Data-type of the returned tensor."
msgstr "返回张量的数据类型。"

#: maxframe.tensor.random.standard_normal.standard_normal of
msgid "返回"
msgstr ""

#: maxframe.tensor.random.standard_normal.standard_normal:14 of
msgid "**out** -- Drawn samples."
msgstr "**out** -- 抽取的样本。"

#: maxframe.tensor.random.standard_normal.standard_normal of
msgid "返回类型"
msgstr ""

#: maxframe.tensor.random.standard_normal.standard_normal:18 of
msgid "示例"
msgstr ""

