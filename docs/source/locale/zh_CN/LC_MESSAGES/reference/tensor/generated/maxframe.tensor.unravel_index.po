#: ../../source/reference/tensor/generated/maxframe.tensor.unravel_index.rst:2
msgid "maxframe.tensor.unravel\\_index"
msgstr ""

#: maxframe.tensor.indexing.unravel_index.unravel_index:1 of
msgid ""
"Converts a flat index or tensor of flat indices into a tuple of "
"coordinate tensors."
msgstr "将一个平坦索引或平坦索引张量转换为坐标张量的元组。"

#: maxframe.tensor.indexing.unravel_index.unravel_index of
msgid "参数"
msgstr ""

#: maxframe.tensor.indexing.unravel_index.unravel_index:4 of
msgid ""
"An integer tensor whose elements are indices into the flattened version "
"of a tensor of dimensions ``dims``."
msgstr "一个整数张量，其元素是维度为 ``dims`` 的张量展平后的索引。"

#: maxframe.tensor.indexing.unravel_index.unravel_index:7 of
msgid "The shape of the tensor to use for unraveling ``indices``."
msgstr "用于展开 ``indices`` 的张量的形状。"

#: maxframe.tensor.indexing.unravel_index.unravel_index:9 of
msgid ""
"Determines whether the indices should be viewed as indexing in row-major "
"(C-style) or column-major (Fortran-style) order."
msgstr "确定索引应被视为按行主序（C 风格）还是列主序（Fortran 风格）进行索引。"

#: maxframe.tensor.indexing.unravel_index.unravel_index of
msgid "返回"
msgstr ""

#: maxframe.tensor.indexing.unravel_index.unravel_index:13 of
msgid ""
"**unraveled_coords** -- Each tensor in the tuple has the same shape as "
"the ``indices`` tensor."
msgstr ""
"**unraveled_coords** -- 元组中的每个张量都与 ``indices`` 张量具有相同的"
"形状。"

#: maxframe.tensor.indexing.unravel_index.unravel_index of
msgid "返回类型"
msgstr ""

