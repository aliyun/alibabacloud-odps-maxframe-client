msgid "Shows which elements are Not a Number (NaN)."
msgstr "显示哪些元素是“非数字”(NaN)。"

#: maxframe.tensor.reduction.nanmin.nanmin:48 of
msgid ":py:obj:`isfinite`"
msgstr ""

#: maxframe.tensor.reduction.nanmin.nanmin:49 of
msgid "Shows which elements are neither NaN nor infinity."
msgstr "显示哪些元素既不是 NaN 也不是无穷大。"

#: maxframe.tensor.reduction.nanmin.nanmin:51 of
msgid ":py:obj:`amax`, :py:obj:`fmax`, :py:obj:`maximum`"
