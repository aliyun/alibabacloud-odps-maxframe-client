#: ../../source/reference/tensor/generated/maxframe.tensor.tril.rst:2
msgid "maxframe.tensor.tril"
msgstr ""

#: maxframe.tensor.datasource.tri_array.tril:1 of
msgid "Lower triangle of a tensor."
msgstr "张量的下三角。"

#: maxframe.tensor.datasource.tri_array.tril:3 of
msgid "Return a copy of a tensor with elements above the `k`-th diagonal zeroed."
msgstr "返回一个张量的副本，其中第 `k` 条对角线以上的元素被置为零。"

#: maxframe.tensor.datasource.tri_array.tril of
msgid "参数"
msgstr ""

#: maxframe.tensor.datasource.tri_array.tril:5 of
msgid "Input tensor."
msgstr "输入张量。"

#: maxframe.tensor.datasource.tri_array.tril:7 of
msgid ""
"Diagonal above which to zero elements.  `k = 0` (the default) is the main"
" diagonal, `k < 0` is below it and `k > 0` is above."
msgstr ""
"置零元素的对角线。`k = 0`（默认值）表示主对角线，`k < 0` 表示主对角线下方"
"，`k > 0` 表示主对角线上方。"

#: maxframe.tensor.datasource.tri_array.tril:10 of
msgid "Allocate the tensor on GPU if True, None as default"
msgstr "如果为 True，则在 GPU 上分配张量，默认为 None"

#: maxframe.tensor.datasource.tri_array.tril of
msgid "返回"
msgstr ""

#: maxframe.tensor.datasource.tri_array.tril:13 of
msgid "**tril** -- Lower triangle of `m`, of same shape and data-type as `m`."
msgstr "**tril** -- 与 `m` 形状和数据类型相同的 `m` 的下三角。"

#: maxframe.tensor.datasource.tri_array.tril of
msgid "返回类型"
msgstr ""

#: maxframe.tensor.datasource.tri_array.tril:18 of
msgid ":py:obj:`triu`"
msgstr ""

#: maxframe.tensor.datasource.tri_array.tril:19 of
msgid "same thing, only for the upper triangle"
msgstr "类似的功能，但用于上三角"

#: maxframe.tensor.datasource.tri_array.tril:22 of
msgid "示例"
msgstr ""

