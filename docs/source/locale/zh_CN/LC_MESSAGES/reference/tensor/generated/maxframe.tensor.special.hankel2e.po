#: maxframe.tensor.special.bessel.hankel2e:19 of
msgid ""
"A wrapper for the AMOS [1]_ routine `zbesh`, which carries out the "
"computation using the relation,"
msgstr "对 AMOS [1]_ 例程 `zbesh` 的封装，该例程使用如下关系进行计算，"

#: maxframe.tensor.special.bessel.hankel2e:22 of
#, python-brace-format
msgid ""
"H^{(2)}_v(z) = -\\frac{2}{\\imath\\pi}\n"
"\\exp(\\frac{\\imath \\pi v}{2}) K_v(z exp(\\frac{\\imath\\pi}{2}))\n"
"\n"
msgstr ""

#: maxframe.tensor.special.bessel.hankel2e:25 of
msgid ""
"where :math:`K_v` is the modified Bessel function of the second kind. For"
" negative orders, the relation"
msgstr "其中 :math:`K_v` 是第二类变形贝塞尔函数。对于负阶数，使用如下关系"

#: maxframe.tensor.special.bessel.hankel2e:28 of
#, python-brace-format
msgid ""
"H^{(2)}_{-v}(z) = H^{(2)}_v(z) \\exp(-\\imath\\pi v)\n"
"\n"
msgstr ""

#: maxframe.tensor.special.bessel.hankel2e:30 of
msgid "is used."
msgstr "。"

