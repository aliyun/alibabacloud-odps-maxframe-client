#: ../../source/reference/tensor/generated/maxframe.tensor.fliplr.rst:2
msgid "maxframe.tensor.fliplr"
msgstr ""

#: maxframe.tensor.misc.fliplr.fliplr:1 of
msgid "Flip tensor in the left/right direction."
msgstr "沿左右方向翻转张量。"

#: maxframe.tensor.misc.fliplr.fliplr:3 of
msgid ""
"Flip the entries in each row in the left/right direction. Columns are "
"preserved, but appear in a different order than before."
msgstr "将每行中的元素沿左右方向翻转。列保持不变，但顺序与之前不同。"

#: maxframe.tensor.misc.fliplr.fliplr of
msgid "参数"
msgstr ""

#: maxframe.tensor.misc.fliplr.fliplr:6 of
msgid "Input tensor, must be at least 2-D."
msgstr "输入张量，必须至少是二维的。"

#: maxframe.tensor.misc.fliplr.fliplr of
msgid "返回"
msgstr ""

#: maxframe.tensor.misc.fliplr.fliplr:9 of
msgid ""
"**f** -- A view of `m` with the columns reversed.  Since a view is "
"returned, this operation is :math:`\\mathcal O(1)`."
msgstr ""
"**f** -- 一个列顺序反转的 `m` 的视图。由于返回的是视图，因此此操作的时间"
"复杂度为 :math:`\\mathcal O(1)`。"

#: maxframe.tensor.misc.fliplr.fliplr of
msgid "返回类型"
msgstr ""

#: maxframe.tensor.misc.fliplr.fliplr:15 of
msgid ":py:obj:`flipud`"
msgstr ""

#: maxframe.tensor.misc.fliplr.fliplr:16 of
msgid "Flip array in the up/down direction."
msgstr "沿上下方向翻转数组。"

#: maxframe.tensor.misc.fliplr.fliplr:18 of
msgid ":py:obj:`rot90`"
msgstr ""

#: maxframe.tensor.misc.fliplr.fliplr:19 of
msgid "Rotate array counterclockwise."
msgstr "将数组逆时针旋转。"

#: maxframe.tensor.misc.fliplr.fliplr:22 of
msgid "备注"
msgstr ""

#: maxframe.tensor.misc.fliplr.fliplr:23 of
msgid "Equivalent to m[:,::-1]. Requires the tensor to be at least 2-D."
msgstr "等价于 m[:,::-1]。要求张量至少为二维。"

#: maxframe.tensor.misc.fliplr.fliplr:26 of
msgid "示例"
msgstr ""

