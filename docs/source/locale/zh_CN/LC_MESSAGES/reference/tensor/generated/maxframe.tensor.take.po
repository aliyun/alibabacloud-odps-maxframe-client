msgstr ""

#: maxframe.tensor.indexing.take.take:20 of
msgid "The source tensor."
msgstr "源张量。"

#: maxframe.tensor.indexing.take.take:22 of
msgid "The indices of the values to extract.  Also allow scalars for indices."
msgstr "要提取的值的索引。也允许标量作为索引。"

#: maxframe.tensor.indexing.take.take:22 of
