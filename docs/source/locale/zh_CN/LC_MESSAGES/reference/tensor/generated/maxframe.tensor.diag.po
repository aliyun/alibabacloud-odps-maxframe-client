#: ../../source/reference/tensor/generated/maxframe.tensor.diag.rst:2
msgid "maxframe.tensor.diag"
msgstr ""

#: maxframe.tensor.datasource.diag.diag:1 of
msgid "Extract a diagonal or construct a diagonal tensor."
msgstr "提取对角线或构造对角线张量。"

#: maxframe.tensor.datasource.diag.diag:3 of
msgid ""
"See the more detailed documentation for ``mt.diagonal`` if you use this "
"function to extract a diagonal and wish to write to the resulting tensor"
msgstr ""
"如果你使用此函数提取对角线并希望写入结果张量，请参阅 ``mt.diagonal`` 的更"
"详细文档"

#: maxframe.tensor.datasource.diag.diag of
msgid "参数"
msgstr ""

#: maxframe.tensor.datasource.diag.diag:6 of
msgid ""
"If `v` is a 2-D tensor, return its `k`-th diagonal. If `v` is a 1-D "
"tensor, return a 2-D tensor with `v` on the `k`-th diagonal."
msgstr ""
"如果 `v` 是一个二维张量，则返回其第 `k` 条对角线。如果 `v` 是一维张量，则"
"返回一个以 `v` 作为第 `k` 条对角线的二维张量。"

#: maxframe.tensor.datasource.diag.diag:10 of
msgid ""
"Diagonal in question. The default is 0. Use `k>0` for diagonals above the"
" main diagonal, and `k<0` for diagonals below the main diagonal."
msgstr ""
"所考虑的对角线。默认值为 0。使用 `k>0` 表示主对角线上方的对角线，使用 `k<"
"0` 表示主对角线下方的对角线。"

#: maxframe.tensor.datasource.diag.diag:14 of
msgid "Create sparse tensor if True, False as default"
msgstr "如果为 True 则创建稀疏张量，默认为 False"

#: maxframe.tensor.datasource.diag.diag:16 of
msgid "Allocate the tensor on GPU if True, False as default"
msgstr "如果为 True 则在 GPU 上分配张量，默认为 False"

#: maxframe.tensor.datasource.diag.diag:18 of
msgid "Desired chunk size on each dimension"
msgstr "每个维度上期望的块大小"

#: maxframe.tensor.datasource.diag.diag of
msgid "返回"
msgstr ""

#: maxframe.tensor.datasource.diag.diag:21 of
msgid "**out** -- The extracted diagonal or constructed diagonal tensor."
msgstr "**out** -- 提取的对角线或构造的对角线张量。"

#: maxframe.tensor.datasource.diag.diag of
msgid "返回类型"
msgstr ""

#: maxframe.tensor.datasource.diag.diag:26 of
msgid ":py:obj:`diagonal`"
msgstr ""

#: maxframe.tensor.datasource.diag.diag:27 of
msgid "Return specified diagonals."
msgstr "返回指定的对角线。"

#: maxframe.tensor.datasource.diag.diag:29 of
msgid ":py:obj:`diagflat`"
msgstr ""

#: maxframe.tensor.datasource.diag.diag:30 of
msgid "Create a 2-D array with the flattened input as a diagonal."
msgstr "创建一个以展平输入作为对角线的二维数组。"

#: maxframe.tensor.datasource.diag.diag:32 of
msgid ":py:obj:`trace`"
msgstr ""

#: maxframe.tensor.datasource.diag.diag:33 of
msgid "Sum along diagonals."
msgstr "沿对角线求和。"

#: maxframe.tensor.datasource.diag.diag:35 of
msgid ":py:obj:`triu`"
msgstr ""

#: maxframe.tensor.datasource.diag.diag:36 of
msgid "Upper triangle of a tensor."
msgstr "张量的上三角部分。"

#: maxframe.tensor.datasource.diag.diag:38 of
msgid ":py:obj:`tril`"
msgstr ""

#: maxframe.tensor.datasource.diag.diag:39 of
msgid "Lower triangle of a tensor."
msgstr "张量的下三角部分。"

#: maxframe.tensor.datasource.diag.diag:42 of
msgid "示例"
msgstr ""

