msgstr ""

#: maxframe.tensor.arithmetic.floordiv.floordiv:29 of
msgid "Simultaneous floor division and remainder."
msgstr "同时进行向下取整除法和求余。"

#: maxframe.tensor.arithmetic.floordiv.floordiv:31 of
