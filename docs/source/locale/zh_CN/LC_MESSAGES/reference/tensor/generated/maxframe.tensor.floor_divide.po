msgstr ""

#: maxframe.tensor.arithmetic.floordiv.floordiv:26 of
msgid "Remainder complementary to floor_divide."
msgstr "与 floor_divide 互补的余数。"

#: maxframe.tensor.arithmetic.floordiv.floordiv:28 of
