#: ../../source/reference/tensor/generated/maxframe.tensor.zeros.rst:2
msgid "maxframe.tensor.zeros"
msgstr ""

#: maxframe.tensor.datasource.zeros.zeros:1 of
msgid "Return a new tensor of given shape and type, filled with zeros."
msgstr "返回一个给定形状和类型的全零新张量。"

#: maxframe.tensor.datasource.zeros.zeros of
msgid "参数"
msgstr ""

#: maxframe.tensor.datasource.zeros.zeros:3 of
msgid "Shape of the new tensor, e.g., ``(2, 3)`` or ``2``."
msgstr "新张量的形状，例如 ``(2, 3)`` 或 ``2``。"

#: maxframe.tensor.datasource.zeros.zeros:5 of
msgid ""
"The desired data-type for the array, e.g., `mt.int8`.  Default is "
"`mt.float64`."
msgstr "数组所需的数据类型，例如 `mt.int8`。默认为 `mt.float64`。"

#: maxframe.tensor.datasource.zeros.zeros:8 of
msgid "Desired chunk size on each dimension"
msgstr "每个维度上的期望块大小"

#: maxframe.tensor.datasource.zeros.zeros:10 of
msgid "Allocate the tensor on GPU if True, False as default"
msgstr "如果为 True，则在 GPU 上分配张量，默认为 False"

#: maxframe.tensor.datasource.zeros.zeros:12 of
msgid "Create sparse tensor if True, False as default"
msgstr "如果为 True，则创建稀疏张量，默认为 False"

#: maxframe.tensor.datasource.zeros.zeros:14 of
msgid ""
"Whether to store multi-dimensional data in row-major (C-style) or column-"
"major (Fortran-style) order in memory."
msgstr "是否以行主序 (C 风格) 或列主序 (Fortran 风格) 在内存中存储多维数据。"

#: maxframe.tensor.datasource.zeros.zeros of
msgid "返回"
msgstr ""

#: maxframe.tensor.datasource.zeros.zeros:19 of
msgid "**out** -- Tensor of zeros with the given shape, dtype, and order."
msgstr "**out** -- 给定形状、数据类型和存储顺序的全零张量。"

#: maxframe.tensor.datasource.zeros.zeros of
msgid "返回类型"
msgstr ""

#: maxframe.tensor.datasource.zeros.zeros:24 of
msgid ":py:obj:`zeros_like`"
msgstr ""

#: maxframe.tensor.datasource.zeros.zeros:25 of
msgid "Return a tensor of zeros with shape and type of input."
msgstr "返回一个与输入具有相同形状和类型的全零张量。"

#: maxframe.tensor.datasource.zeros.zeros:27 of
msgid ":py:obj:`ones_like`"
msgstr ""

#: maxframe.tensor.datasource.zeros.zeros:28 of
msgid "Return a tensor of ones with shape and type of input."
msgstr "返回一个与输入具有相同形状和类型的全一张量。"

#: maxframe.tensor.datasource.zeros.zeros:30 of
msgid ":py:obj:`empty_like`"
msgstr ""

#: maxframe.tensor.datasource.zeros.zeros:31 of
msgid "Return a empty tensor with shape and type of input."
msgstr "返回一个与输入具有相同形状和类型的未初始化张量。"

#: maxframe.tensor.datasource.zeros.zeros:33 of
msgid ":py:obj:`ones`"
msgstr ""

#: maxframe.tensor.datasource.zeros.zeros:34 of
msgid "Return a new tensor setting values to one."
msgstr "返回一个将值设为 1 的新张量。"

#: maxframe.tensor.datasource.zeros.zeros:36 of
msgid ":py:obj:`empty`"
msgstr ""

#: maxframe.tensor.datasource.zeros.zeros:37 of
msgid "Return a new uninitialized tensor."
msgstr "返回一个未初始化的新张量。"

