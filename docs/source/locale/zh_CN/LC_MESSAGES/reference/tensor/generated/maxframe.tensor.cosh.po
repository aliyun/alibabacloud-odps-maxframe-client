#: ../../source/reference/tensor/generated/maxframe.tensor.cosh.rst:2
msgid "maxframe.tensor.cosh"
msgstr ""

#: maxframe.tensor.arithmetic.cosh.cosh:1 of
msgid "Hyperbolic cosine, element-wise."
msgstr "逐元素计算双曲余弦值。"

#: maxframe.tensor.arithmetic.cosh.cosh:3 of
msgid "Equivalent to ``1/2 * (mt.exp(x) + mt.exp(-x))`` and ``mt.cos(1j*x)``."
msgstr "等价于 ``1/2 * (mt.exp(x) + mt.exp(-x))`` 和 ``mt.cos(1j*x)``。"

#: maxframe.tensor.arithmetic.cosh.cosh of
msgid "参数"
msgstr ""

#: maxframe.tensor.arithmetic.cosh.cosh:5 of
msgid "Input tensor."
msgstr "输入张量。"

#: maxframe.tensor.arithmetic.cosh.cosh:7 of
msgid ""
"A location into which the result is stored. If provided, it must have a "
"shape that the inputs broadcast to. If not provided or `None`, a freshly-"
"allocated tensor is returned. A tuple (possible only as a keyword "
"argument) must have length equal to the number of outputs."
msgstr ""
"用于存储结果的位置。如果提供，其形状必须可以广播至输入形状。如果未提供或"
"为 `None`，则返回一个新分配的张量。元组（只能作为关键字参数）的长度必须"
"等于输出数量。"

#: maxframe.tensor.arithmetic.cosh.cosh:12 of
msgid ""
"Values of True indicate to calculate the ufunc at that position, values "
"of False indicate to leave the value in the output alone."
msgstr "为 True 的值表示在该位置计算 ufunc，为 False 的值表示保留输出中的原始值。"

#: maxframe.tensor.arithmetic.cosh.cosh of
msgid "返回"
msgstr ""

#: maxframe.tensor.arithmetic.cosh.cosh:17 of
msgid "**out** -- Output array of same shape as `x`."
msgstr "**out** -- 与 `x` 形状相同的输出数组。"

#: maxframe.tensor.arithmetic.cosh.cosh of
msgid "返回类型"
msgstr ""

#: maxframe.tensor.arithmetic.cosh.cosh:21 of
msgid "示例"
msgstr ""

#: maxframe.tensor.arithmetic.cosh.cosh:27 of
msgid "The hyperbolic cosine describes the shape of a hanging cable:"
msgstr "双曲余弦函数描述了悬挂电缆的形状："

