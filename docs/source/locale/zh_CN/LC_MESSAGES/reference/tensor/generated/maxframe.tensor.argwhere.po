#: ../../source/reference/tensor/generated/maxframe.tensor.argwhere.rst:2
msgid "maxframe.tensor.argwhere"
msgstr ""

#: maxframe.tensor.misc.argwhere.argwhere:1 of
msgid "Find the indices of tensor elements that are non-zero, grouped by element."
msgstr "查找张量中非零元素的索引，并按元素分组。"

#: maxframe.tensor.misc.argwhere.argwhere of
msgid "参数"
msgstr ""

#: maxframe.tensor.misc.argwhere.argwhere:3 of
msgid "Input data."
msgstr "输入数据。"

#: maxframe.tensor.misc.argwhere.argwhere of
msgid "返回"
msgstr ""

#: maxframe.tensor.misc.argwhere.argwhere:6 of
msgid ""
"**index_tensor** -- Indices of elements that are non-zero. Indices are "
"grouped by element."
msgstr "**index_tensor** -- 非零元素的索引。索引按元素分组。"

#: maxframe.tensor.misc.argwhere.argwhere of
msgid "返回类型"
msgstr ""

#: maxframe.tensor.misc.argwhere.argwhere:9 of
msgid ":py:obj:`where`, :py:obj:`nonzero`"
msgstr ""

#: maxframe.tensor.misc.argwhere.argwhere:12 of
msgid "备注"
msgstr ""

#: maxframe.tensor.misc.argwhere.argwhere:13 of
msgid "``mt.argwhere(a)`` is the same as ``mt.transpose(mt.nonzero(a))``."
msgstr "``mt.argwhere(a)`` 等价于 ``mt.transpose(mt.nonzero(a))``。"

#: maxframe.tensor.misc.argwhere.argwhere:15 of
msgid ""
"The output of ``argwhere`` is not suitable for indexing tensors. For this"
" purpose use ``nonzero(a)`` instead."
msgstr "``argwhere`` 的输出不适合用于索引张量。为此，请使用 ``nonzero(a)``。"

