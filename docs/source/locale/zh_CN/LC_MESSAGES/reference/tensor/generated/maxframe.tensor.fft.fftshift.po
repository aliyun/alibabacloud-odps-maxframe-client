#: ../../source/reference/tensor/generated/maxframe.tensor.fft.fftshift.rst:2
msgid "maxframe.tensor.fft.fftshift"
msgstr ""

#: maxframe.tensor.fft.fftshift.fftshift:1 of
msgid "Shift the zero-frequency component to the center of the spectrum."
msgstr "将零频分量移至频谱中心。"

#: maxframe.tensor.fft.fftshift.fftshift:3 of
msgid ""
"This function swaps half-spaces for all axes listed (defaults to all). "
"Note that ``y[0]`` is the Nyquist component only if ``len(x)`` is even."
msgstr ""
"此函数会交换所有指定轴的半空间（默认为所有轴）。注意，仅当 ``len(x)`` 为"
"偶数时，``y[0]`` 才是奈奎斯特分量。"

#: maxframe.tensor.fft.fftshift.fftshift of
msgid "参数"
msgstr ""

#: maxframe.tensor.fft.fftshift.fftshift:6 of
msgid "Input tensor."
msgstr "输入张量。"

#: maxframe.tensor.fft.fftshift.fftshift:8 of
msgid "Axes over which to shift.  Default is None, which shifts all axes."
msgstr "指定进行移位的轴。默认为 None，表示对所有轴进行移位。"

#: maxframe.tensor.fft.fftshift.fftshift of
msgid "返回"
msgstr ""

#: maxframe.tensor.fft.fftshift.fftshift:11 of
msgid "**y** -- The shifted tensor."
msgstr "**y** -- 移位后的张量。"

#: maxframe.tensor.fft.fftshift.fftshift of
msgid "返回类型"
msgstr ""

#: maxframe.tensor.fft.fftshift.fftshift:16 of
msgid ":py:obj:`ifftshift`"
msgstr ""

#: maxframe.tensor.fft.fftshift.fftshift:17 of
msgid "The inverse of `fftshift`."
msgstr "`fftshift` 的逆操作。"

#: maxframe.tensor.fft.fftshift.fftshift:20 of
msgid "示例"
msgstr ""

#: maxframe.tensor.fft.fftshift.fftshift:29 of
msgid "Shift the zero-frequency component only along the second axis:"
msgstr "仅沿第二轴移动零频分量："

