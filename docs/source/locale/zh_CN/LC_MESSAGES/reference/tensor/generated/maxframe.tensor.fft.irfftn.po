msgid "抛出"
msgstr ""

#: maxframe.tensor.fft.irfftn.irfftn:44 of
msgid "If `s` and `axes` have different length."
msgstr "如果 `s` 和 `axes` 长度不同。"

#: maxframe.tensor.fft.irfftn.irfftn:45 of
msgid "If an element of `axes` is larger than than the number of axes of `a`."
msgstr "如果 `axes` 的某个元素大于 `a` 的轴数。"

