msgid "maxframe.tensor.special.ellipeinc"
msgstr ""

#: maxframe.tensor.special.ellip_func_integrals.ellipeinc:1 of
msgid "Incomplete elliptic integral of the second kind"
msgstr "第二类不完全椭圆积分"

#: maxframe.tensor.special.ellip_func_integrals.ellipeinc:3 of
msgid "This function is defined as"
msgstr "该函数定义为"

#: maxframe.tensor.special.ellip_func_integrals.ellipeinc:5 of
#, python-brace-format
msgid ""
"E(\\phi, m) = \\int_0^{\\phi} [1 - m \\sin(t)^2]^{1/2} dt\n"
"\n"
msgstr ""

#: ../../source/reference/tensor/generated/maxframe.tensor.special.ellipeinc.rst
msgid "参数"
msgstr ""

#: maxframe.tensor.special.ellip_func_integrals.ellipeinc:7 of
msgid "amplitude of the elliptic integral."
msgstr "椭圆积分的幅度。"

#: maxframe.tensor.special.ellip_func_integrals.ellipeinc:9 of
msgid "parameter of the elliptic integral."
msgstr "椭圆积分的参数。"

#: maxframe.tensor.special.ellip_func_integrals.ellipeinc:11 of
msgid "Optional output array for the function values"
msgstr "函数值的可选输出数组"

#: ../../source/reference/tensor/generated/maxframe.tensor.special.ellipeinc.rst
msgid "返回"
msgstr ""

#: maxframe.tensor.special.ellip_func_integrals.ellipeinc:14 of
msgid "**E** -- Value of the elliptic integral."
msgstr "**E** -- 椭圆积分的值。"

#: ../../source/reference/tensor/generated/maxframe.tensor.special.ellipeinc.rst
msgid "返回类型"
msgstr ""

