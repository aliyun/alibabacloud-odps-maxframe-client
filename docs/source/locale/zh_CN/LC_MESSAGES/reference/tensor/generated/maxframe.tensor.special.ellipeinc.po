msgstr ""

#: maxframe.tensor.special.ellip_func_integrals.ellipeinc:26 of
msgid "Incomplete elliptic integral of the first kind"
msgstr "第一类不完全椭圆积分"

#: maxframe.tensor.special.ellip_func_integrals.ellipeinc:28 of
