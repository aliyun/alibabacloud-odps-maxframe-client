#: ../../source/reference/tensor/generated/maxframe.tensor.ediff1d.rst:2
msgid "maxframe.tensor.ediff1d"
msgstr ""

#: maxframe.tensor.misc.ediff1d.ediff1d:1 of
msgid "The differences between consecutive elements of a tensor."
msgstr "张量中连续元素之间的差值。"

#: maxframe.tensor.misc.ediff1d.ediff1d of
msgid "参数"
msgstr ""

#: maxframe.tensor.misc.ediff1d.ediff1d:3 of
msgid "If necessary, will be flattened before the differences are taken."
msgstr "如有必要，将在计算差值之前将其展平。"

#: maxframe.tensor.misc.ediff1d.ediff1d:5 of
msgid "Number(s) to append at the end of the returned differences."
msgstr "附加在返回差值末尾的数字。"

#: maxframe.tensor.misc.ediff1d.ediff1d:7 of
msgid "Number(s) to prepend at the beginning of the returned differences."
msgstr "前置在返回差值开头的数字。"

#: maxframe.tensor.misc.ediff1d.ediff1d of
msgid "返回"
msgstr ""

#: maxframe.tensor.misc.ediff1d.ediff1d:10 of
msgid ""
"**ediff1d** -- The differences. Loosely, this is ``a.flat[1:] - "
"a.flat[:-1]``."
msgstr "**ediff1d** -- 差值。大致上，这是 ``a.flat[1:] - a.flat[:-1]``。"

#: maxframe.tensor.misc.ediff1d.ediff1d of
msgid "返回类型"
msgstr ""

#: maxframe.tensor.misc.ediff1d.ediff1d:13 of
msgid ":py:obj:`diff`, :py:obj:`gradient`"
msgstr ""

#: maxframe.tensor.misc.ediff1d.ediff1d:16 of
msgid "示例"
msgstr ""

#: maxframe.tensor.misc.ediff1d.ediff1d:26 of
msgid "The returned tensor is always 1D."
msgstr "返回的张量始终是一维的。"

