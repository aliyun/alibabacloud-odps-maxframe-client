msgid "maxframe.tensor.fft.ifftshift"
msgstr ""

#: maxframe.tensor.fft.ifftshift.ifftshift:1 of
msgid ""
"The inverse of `fftshift`. Although identical for even-length `x`, the "
"functions differ by one sample for odd-length `x`."
msgstr ""
" `fftshift` 的逆操作。对于偶数长度的 `x` 两者相同，但对于奇数长度的 `x` "
"两者相差一个样本。"

#: maxframe.tensor.fft.ifftshift.ifftshift of
msgid "参数"
msgstr ""

#: maxframe.tensor.fft.ifftshift.ifftshift:4 of
msgid "Input tensor."
msgstr "输入张量。"

#: maxframe.tensor.fft.ifftshift.ifftshift:6 of
msgid "Axes over which to calculate.  Defaults to None, which shifts all axes."
msgstr "进行计算的轴。默认为 None，表示对所有轴进行偏移。"

#: maxframe.tensor.fft.ifftshift.ifftshift of
msgid "返回"
msgstr ""

#: maxframe.tensor.fft.ifftshift.ifftshift:9 of
msgid "**y** -- The shifted tensor."
msgstr "**y** —— 偏移后的张量。"

#: maxframe.tensor.fft.ifftshift.ifftshift of
msgid "返回类型"
msgstr ""

#: maxframe.tensor.fft.ifftshift.ifftshift:14 of
msgid ":py:obj:`fftshift`"
msgstr ""

#: maxframe.tensor.fft.ifftshift.ifftshift:15 of
msgid "Shift zero-frequency component to the center of the spectrum."
msgstr "将零频分量移到频谱中心。"

