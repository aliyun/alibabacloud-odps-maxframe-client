#: maxframe.tensor.reduction.array_equal.array_equal:1 of
msgid "True if two tensors have the same shape and elements, False otherwise."
msgstr "如果两个张量具有相同的形状和元素则返回 True，否则返回 False。"

#: maxframe.tensor.reduction.array_equal.array_equal of
msgid "参数"
msgstr ""

#: maxframe.tensor.reduction.array_equal.array_equal:3
#: maxframe.tensor.reduction.array_equal.array_equal:5 of
msgid "Input arrays."
msgstr "输入数组。"

#: maxframe.tensor.reduction.array_equal.array_equal of
msgid "返回"
msgstr ""

#: maxframe.tensor.reduction.array_equal.array_equal:8 of
msgid "**b** -- Returns True if the tensors are equal."
msgstr "**b** -- 如果张量相等则返回 True。"

#: maxframe.tensor.reduction.array_equal.array_equal of
msgid "返回类型"
msgstr ""

#: maxframe.tensor.reduction.array_equal.array_equal:13 of
msgid ":py:obj:`allclose`"
msgstr ""

#: maxframe.tensor.reduction.array_equal.array_equal:14 of
msgid "Returns True if two tensors are element-wise equal within a tolerance."
msgstr "如果两个张量在容差范围内逐元素相等则返回 True。"

#: maxframe.tensor.reduction.array_equal.array_equal:16 of
msgid ":py:obj:`array_equiv`"
msgstr ""

#: maxframe.tensor.reduction.array_equal.array_equal:17 of
msgid "Returns True if input tensors are shape consistent and all elements equal."
msgstr "如果输入张量形状一致且所有元素相等则返回 True。"

