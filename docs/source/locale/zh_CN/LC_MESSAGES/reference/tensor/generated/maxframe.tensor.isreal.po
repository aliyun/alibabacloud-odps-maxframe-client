#: maxframe.tensor.arithmetic.isreal.isreal:1 of
msgid "Returns a bool tensor, where True if input element is real."
msgstr "返回一个布尔张量，如果输入元素是实数则为 True。"

#: maxframe.tensor.arithmetic.isreal.isreal:3 of
msgid ""
"If element has complex type with zero complex part, the return value for "
"that element is True."
msgstr "如果元素具有复数类型且虚部为零，则该元素的返回值为 True。"

#: maxframe.tensor.arithmetic.isreal.isreal of
msgid "参数"
msgstr ""

#: maxframe.tensor.arithmetic.isreal.isreal:6 of
msgid "Input tensor."
msgstr "输入张量。"

#: maxframe.tensor.arithmetic.isreal.isreal of
msgid "返回"
msgstr ""

#: maxframe.tensor.arithmetic.isreal.isreal:9 of
msgid "**out** -- Boolean tensor of same shape as `x`."
msgstr "**out** -- 与 `x` 形状相同的布尔张量。"

#: maxframe.tensor.arithmetic.isreal.isreal of
msgid "返回类型"
msgstr ""

#: maxframe.tensor.arithmetic.isreal.isreal:14 of
msgid ":py:obj:`iscomplex`"
msgstr ""

#: maxframe.tensor.arithmetic.isreal.isreal:16 of
msgid ":py:obj:`isrealobj`"
msgstr ""

#: maxframe.tensor.arithmetic.isreal.isreal:17 of
msgid "Return True if x is not a complex type."
msgstr "如果 x 不是复数类型则返回 True。"

