msgid "**out** -- Output tensor."
msgstr "**out** -- 输出张量。"

#: maxframe.tensor.arithmetic.iscomplex.iscomplex of
msgid "返回类型"
msgstr ""

#: maxframe.tensor.arithmetic.iscomplex.iscomplex:14 of
