#: maxframe.tensor.misc.atleast_1d.atleast_1d:1 of
msgid "Convert inputs to tensors with at least one dimension."
msgstr "将输入转换为至少一维的张量。"

#: maxframe.tensor.misc.atleast_1d.atleast_1d:3 of
msgid ""
"Scalar inputs are converted to 1-dimensional tensors, whilst higher-"
"dimensional inputs are preserved."
msgstr "标量输入会被转换为一维张量，而高维输入则保持不变。"

#: maxframe.tensor.misc.atleast_1d.atleast_1d of
msgid "参数"
msgstr ""

#: maxframe.tensor.misc.atleast_1d.atleast_1d:6
#: maxframe.tensor.misc.atleast_1d.atleast_1d:8
#: maxframe.tensor.misc.atleast_1d.atleast_1d:10 of
msgid "One or more input tensors."
msgstr "一个或多个输入张量。"

#: maxframe.tensor.misc.atleast_1d.atleast_1d of
msgid "返回"
msgstr ""

#: maxframe.tensor.misc.atleast_1d.atleast_1d:13 of
msgid ""
"**ret** -- An tensor, or list of tensors, each with ``a.ndim >= 1``. "
"Copies are made only if necessary."
msgstr "**ret** —— 一个张量或张量列表，每个张量都满足 ``a.ndim >= 1``。仅在必要时才会进行复制。"

