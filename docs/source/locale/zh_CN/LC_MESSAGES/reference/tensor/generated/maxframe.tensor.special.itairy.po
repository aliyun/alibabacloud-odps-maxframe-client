#: ../../source/reference/tensor/generated/maxframe.tensor.special.itairy.rst:2
msgid "maxframe.tensor.special.itairy"
msgstr ""

#: maxframe.tensor.special.airy.itairy:1 of
msgid "Integrals of Airy functions"
msgstr "Airy 函数的积分"

#: maxframe.tensor.special.airy.itairy:3 of
msgid "Calculates the integrals of Airy functions from 0 to `x`."
msgstr "计算从 0 到 `x` 的 Airy 函数积分。"

#: ../../source/reference/tensor/generated/maxframe.tensor.special.itairy.rst
msgid "参数"
msgstr ""

#: maxframe.tensor.special.airy.itairy:5 of
msgid "Upper limit of integration (float)."
msgstr "积分上限（浮点数）。"

#: maxframe.tensor.special.airy.itairy:7 of
msgid "Optional output arrays for the function values"
msgstr "函数值的可选输出数组"

#: ../../source/reference/tensor/generated/maxframe.tensor.special.itairy.rst
msgid "返回"
msgstr ""

#: maxframe.tensor.special.airy.itairy:10 of
msgid ""
"* **Apt** (*scalar or ndarray*) -- Integral of Ai(t) from 0 to x. * "
"**Bpt** (*scalar or ndarray*) -- Integral of Bi(t) from 0 to x. * **Ant**"
" (*scalar or ndarray*) -- Integral of Ai(-t) from 0 to x. * **Bnt** "
"(*scalar or ndarray*) -- Integral of Bi(-t) from 0 to x."
msgstr ""
"* **Apt** (*scalar or ndarray*) -- 从 0 到 x 的 Ai(t) 的积分。* **Bpt** ("
"*scalar or ndarray*) -- 从 0 到 x 的 Bi(t) 的积分。* **Ant** (*scalar or "
"ndarray*) -- 从 0 到 x 的 Ai(-t) 的积分。* **Bnt** (*scalar or ndarray*) "
"-- 从 0 到 x 的 Bi(-t) 的积分。"

#: maxframe.tensor.special.airy.itairy:10 of
msgid "**Apt** (*scalar or ndarray*) -- Integral of Ai(t) from 0 to x."
msgstr "**Apt** (*scalar or ndarray*) -- 从 0 到 x 的 Ai(t) 的积分。"

#: maxframe.tensor.special.airy.itairy:11 of
msgid "**Bpt** (*scalar or ndarray*) -- Integral of Bi(t) from 0 to x."
msgstr "**Bpt** (*scalar or ndarray*) -- 从 0 到 x 的 Bi(t) 的积分。"

#: maxframe.tensor.special.airy.itairy:12 of
msgid "**Ant** (*scalar or ndarray*) -- Integral of Ai(-t) from 0 to x."
msgstr "**Ant** (*scalar or ndarray*) -- 从 0 到 x 的 Ai(-t) 的积分。"

#: maxframe.tensor.special.airy.itairy:13 of
msgid "**Bnt** (*scalar or ndarray*) -- Integral of Bi(-t) from 0 to x."
msgstr "**Bnt** (*scalar or ndarray*) -- 从 0 到 x 的 Bi(-t) 的积分。"

#: maxframe.tensor.special.airy.itairy:16 of
msgid "备注"
msgstr ""

