#: ../../source/reference/tensor/generated/maxframe.tensor.rollaxis.rst:2
msgid "maxframe.tensor.rollaxis"
msgstr ""

#: maxframe.tensor.misc.rollaxis.rollaxis:1 of
msgid "Roll the specified axis backwards, until it lies in a given position."
msgstr "将指定轴向后滚动，直到它位于给定位置。"

#: maxframe.tensor.misc.rollaxis.rollaxis:3 of
msgid ""
"This function continues to be supported for backward compatibility, but "
"you should prefer `moveaxis`."
msgstr "此函数为了向后兼容仍然支持，但建议使用 `moveaxis`。"

#: maxframe.tensor.misc.rollaxis.rollaxis of
msgid "参数"
msgstr ""

#: maxframe.tensor.misc.rollaxis.rollaxis:6 of
msgid "Input tensor."
msgstr "输入张量。"

#: maxframe.tensor.misc.rollaxis.rollaxis:8 of
msgid ""
"The axis to roll backwards.  The positions of the other axes do not "
"change relative to one another."
msgstr "要向后滚动的轴。其他轴的位置相对于彼此不会改变。"

#: maxframe.tensor.misc.rollaxis.rollaxis:11 of
msgid ""
"The axis is rolled until it lies before this position.  The default, 0, "
"results in a \"complete\" roll."
msgstr "轴会一直滚动到位于此位置之前。默认值为 0，表示进行“完整”滚动。"

#: maxframe.tensor.misc.rollaxis.rollaxis of
msgid "返回"
msgstr ""

#: maxframe.tensor.misc.rollaxis.rollaxis:15 of
msgid "**res** -- a view of `a` is always returned."
msgstr "**res** -- 总是返回 `a` 的视图。"

#: maxframe.tensor.misc.rollaxis.rollaxis of
msgid "返回类型"
msgstr ""

#: maxframe.tensor.misc.rollaxis.rollaxis:20 of
msgid ":py:obj:`moveaxis`"
msgstr ""

#: maxframe.tensor.misc.rollaxis.rollaxis:21 of
msgid "Move array axes to new positions."
msgstr "将数组轴移动到新位置。"

#: maxframe.tensor.misc.rollaxis.rollaxis:23 of
msgid ":py:obj:`roll`"
msgstr ""

#: maxframe.tensor.misc.rollaxis.rollaxis:24 of
msgid "Roll the elements of an array by a number of positions along a given axis."
msgstr "沿给定轴将数组元素滚动指定位置数。"

#: maxframe.tensor.misc.rollaxis.rollaxis:27 of
msgid "示例"
