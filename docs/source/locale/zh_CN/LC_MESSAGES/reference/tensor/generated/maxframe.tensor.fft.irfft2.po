#: ../../source/reference/tensor/generated/maxframe.tensor.fft.irfft2.rst:2
msgid "maxframe.tensor.fft.irfft2"
msgstr ""

#: maxframe.tensor.fft.irfft2.irfft2:1 of
msgid "Compute the 2-dimensional inverse FFT of a real array."
msgstr "计算实数数组的二维逆FFT。"

#: maxframe.tensor.fft.irfft2.irfft2 of
msgid "参数"
msgstr ""

#: maxframe.tensor.fft.irfft2.irfft2:3 of
msgid "The input tensor"
msgstr "输入张量"

#: maxframe.tensor.fft.irfft2.irfft2:5 of
msgid "Shape of the inverse FFT."
msgstr "逆FFT的形状。"

#: maxframe.tensor.fft.irfft2.irfft2:7 of
msgid ""
"The axes over which to compute the inverse fft. Default is the last two "
"axes."
msgstr "计算逆FFT的轴。默认是最后两个轴。"

#: maxframe.tensor.fft.irfft2.irfft2:10 of
msgid "Normalization mode (see `mt.fft`). Default is None."
msgstr "归一化模式（参见`mt.fft`）。默认为None。"

#: maxframe.tensor.fft.irfft2.irfft2 of
msgid "返回"
msgstr ""

#: maxframe.tensor.fft.irfft2.irfft2:13 of
msgid "**out** -- The result of the inverse real 2-D FFT."
msgstr "**out** -- 实数二维逆FFT的结果。"

#: maxframe.tensor.fft.irfft2.irfft2 of
msgid "返回类型"
msgstr ""

#: maxframe.tensor.fft.irfft2.irfft2:18 of
msgid ":py:obj:`irfftn`"
msgstr ""

#: maxframe.tensor.fft.irfft2.irfft2:19 of
msgid "Compute the inverse of the N-dimensional FFT of real input."
msgstr "计算实数输入的N维FFT的逆。"

#: maxframe.tensor.fft.irfft2.irfft2:22 of
msgid "备注"
msgstr ""

#: maxframe.tensor.fft.irfft2.irfft2:23 of
msgid ""
"This is really `irfftn` with different defaults. For more details see "
"`irfftn`."
msgstr "这实际上是具有不同默认值的`irfftn`。更多详情请参见`irfftn`。"

