#: ../../source/reference/tensor/generated/maxframe.tensor.logical_and.rst:2
msgid "maxframe.tensor.logical\\_and"
msgstr ""

#: maxframe.tensor.arithmetic.logical_and.logical_and:1 of
msgid "Compute the truth value of x1 AND x2 element-wise."
msgstr "逐元素计算 x1 和 x2 的逻辑与真值。"

#: maxframe.tensor.arithmetic.logical_and.logical_and of
msgid "参数"
msgstr ""

#: maxframe.tensor.arithmetic.logical_and.logical_and:3
#: maxframe.tensor.arithmetic.logical_and.logical_and:5 of
msgid "Input tensors. `x1` and `x2` must be of the same shape."
msgstr "输入张量。`x1` 和 `x2` 必须具有相同的形状。"

#: maxframe.tensor.arithmetic.logical_and.logical_and:7 of
msgid ""
"A location into which the result is stored. If provided, it must have a "
"shape that the inputs broadcast to. If not provided or `None`, a freshly-"
"allocated tensor is returned. A tuple (possible only as a keyword "
"argument) must have length equal to the number of outputs."
msgstr ""
"用于存储结果的位置。如果提供，其形状必须可以广播到输入的形状。如果未提供"
"或为 `None`，则返回一个新分配的张量。元组（只能作为关键字参数）的长度必须"
"等于输出的数量。"

#: maxframe.tensor.arithmetic.logical_and.logical_and:12 of
msgid ""
"Values of True indicate to calculate the ufunc at that position, values "
"of False indicate to leave the value in the output alone."
msgstr "值为 True 表示在该位置计算 ufunc，值为 False 表示保留输出中的值不变。"

#: maxframe.tensor.arithmetic.logical_and.logical_and of
msgid "返回"
msgstr ""

#: maxframe.tensor.arithmetic.logical_and.logical_and:17 of
msgid ""
"**y** -- Boolean result with the same shape as `x1` and `x2` of the "
"logical AND operation on corresponding elements of `x1` and `x2`."
msgstr ""
"**y** -- 布尔型结果，形状与 `x1` 和 `x2` 相同，表示对应元素的逻辑与运算"
"结果。"

#: maxframe.tensor.arithmetic.logical_and.logical_and of
msgid "返回类型"
msgstr ""

#: maxframe.tensor.arithmetic.logical_and.logical_and:21 of
msgid ""
":py:obj:`logical_or`, :py:obj:`logical_not`, :py:obj:`logical_xor`, "
":py:obj:`bitwise_and`"
msgstr ""

