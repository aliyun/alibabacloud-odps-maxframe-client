msgid "maxframe.tensor.concatenate"
msgstr ""

#: maxframe.tensor.merge.concatenate.concatenate:1 of
msgid "Join a sequence of arrays along an existing axis."
msgstr "沿现有轴连接数组序列。"

#: maxframe.tensor.merge.concatenate.concatenate of
msgid "参数"
msgstr ""

#: maxframe.tensor.merge.concatenate.concatenate:3
#: maxframe.tensor.merge.concatenate.concatenate:6
#: maxframe.tensor.merge.concatenate.concatenate:9 of
msgid ""
"The tensors must have the same shape, except in the dimension "
"corresponding to `axis` (the first, by default)."
msgstr "除了对应于 `axis` 的维度（默认为第一个）外，这些张量必须具有相同的形状。"

#: maxframe.tensor.merge.concatenate.concatenate:12 of
msgid "The axis along which the tensors will be joined.  Default is 0."
msgstr "沿其连接张量的轴。默认为 0。"

#: maxframe.tensor.merge.concatenate.concatenate of
msgid "返回"
msgstr ""

#: maxframe.tensor.merge.concatenate.concatenate:15 of
msgid "**res** -- The concatenated tensor."
msgstr "**res** -- 连接后的张量。"

#: maxframe.tensor.merge.concatenate.concatenate of
msgid "返回类型"
msgstr ""

#: maxframe.tensor.merge.concatenate.concatenate:20 of
msgid ":py:obj:`stack`"
msgstr ""

#: maxframe.tensor.merge.concatenate.concatenate:21 of
msgid "Stack a sequence of tensors along a new axis."
msgstr "沿新轴堆叠张量序列。"

#: maxframe.tensor.merge.concatenate.concatenate:23 of
msgid ":py:obj:`vstack`"
msgstr ""

#: maxframe.tensor.merge.concatenate.concatenate:24 of
msgid "Stack tensors in sequence vertically (row wise)"
msgstr "按顺序垂直堆叠张量（按行）"

