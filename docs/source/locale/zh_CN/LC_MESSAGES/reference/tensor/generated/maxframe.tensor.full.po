#: ../../source/reference/tensor/generated/maxframe.tensor.full.rst:2
msgid "maxframe.tensor.full"
msgstr ""

#: maxframe.tensor.datasource.full.full:1 of
msgid "Return a new tensor of given shape and type, filled with `fill_value`."
msgstr "返回一个给定形状和类型的张量，其元素全部填充为 `fill_value`。"

#: maxframe.tensor.datasource.full.full of
msgid "参数"
msgstr ""

#: maxframe.tensor.datasource.full.full:3 of
msgid "Shape of the new tensor, e.g., ``(2, 3)`` or ``2``."
msgstr "新张量的形状，例如 ``(2, 3)`` 或 ``2``。"

#: maxframe.tensor.datasource.full.full:5 of
msgid "Fill value."
msgstr "填充值。"

#: maxframe.tensor.datasource.full.full:7 of
msgid ""
"The desired data-type for the tensor  The default, `None`, means  "
"`np.array(fill_value).dtype`."
msgstr "张量的期望数据类型。默认值 `None` 表示 `np.array(fill_value).dtype`。"

#: maxframe.tensor.datasource.full.full:8 of
msgid "The desired data-type for the tensor  The default, `None`, means"
msgstr "张量所需的数据类型，默认值 `None` 表示"

#: maxframe.tensor.datasource.full.full:9 of
msgid "`np.array(fill_value).dtype`."
msgstr "`np.array(fill_value).dtype`。"

#: maxframe.tensor.datasource.full.full:11 of
msgid "Desired chunk size on each dimension"
msgstr "每个维度上的期望块大小"

#: maxframe.tensor.datasource.full.full:13 of
msgid "Allocate the tensor on GPU if True, False as default"
msgstr "如果为 True，则将张量分配在 GPU 上，默认为 False"

#: maxframe.tensor.datasource.full.full:15 of
msgid ""
"Whether to store multidimensional data in C- or Fortran-contiguous (row- "
"or column-wise) order in memory."
msgstr "是否以 C 或 Fortran 连续（行或列优先）顺序在内存中存储多维数据。"

#: maxframe.tensor.datasource.full.full of
msgid "返回"
msgstr ""

#: maxframe.tensor.datasource.full.full:19 of
msgid "**out** -- Tensor of `fill_value` with the given shape, dtype, and order."
msgstr "**out** -- 具有给定形状、数据类型和内存顺序的 `fill_value` 张量。"

#: maxframe.tensor.datasource.full.full of
msgid "返回类型"
msgstr ""

#: maxframe.tensor.datasource.full.full:24 of
msgid ":py:obj:`zeros_like`"
msgstr ""

#: maxframe.tensor.datasource.full.full:25 of
msgid "Return a tensor of zeros with shape and type of input."
msgstr "返回一个形状和类型与输入相同的零张量。"

#: maxframe.tensor.datasource.full.full:27 of
msgid ":py:obj:`ones_like`"
msgstr ""

#: maxframe.tensor.datasource.full.full:28 of
msgid "Return a tensor of ones with shape and type of input."
msgstr "返回一个形状和类型与输入相同的全一张量。"

#: maxframe.tensor.datasource.full.full:30 of
msgid ":py:obj:`empty_like`"
msgstr ""

#: maxframe.tensor.datasource.full.full:31 of
msgid "Return an empty tensor with shape and type of input."
msgstr "返回一个形状和类型与输入相同但未初始化的张量。"

#: maxframe.tensor.datasource.full.full:33 of
msgid ":py:obj:`full_like`"
msgstr ""

#: maxframe.tensor.datasource.full.full:34 of
msgid "Fill a tensor with shape and type of input."
msgstr "用输入的形状和类型填充一个张量。"

#: maxframe.tensor.datasource.full.full:36 of
msgid ":py:obj:`zeros`"
msgstr ""

#: maxframe.tensor.datasource.full.full:37 of
msgid "Return a new tensor setting values to zero."
msgstr "返回一个将所有值设为零的新张量。"

#: maxframe.tensor.datasource.full.full:39 of
msgid ":py:obj:`ones`"
msgstr ""

#: maxframe.tensor.datasource.full.full:40 of
msgid "Return a new tensor setting values to one."
msgstr "返回一个将所有值设为一的新张量。"

#: maxframe.tensor.datasource.full.full:42 of
msgid ":py:obj:`empty`"
msgstr ""

#: maxframe.tensor.datasource.full.full:43 of
msgid "Return a new uninitialized tensor."
msgstr "返回一个未初始化的新张量。"

