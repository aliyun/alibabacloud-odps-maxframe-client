#: ../../source/reference/tensor/generated/maxframe.tensor.random.standard_exponential.rst:2
msgid "maxframe.tensor.random.standard\\_exponential"
msgstr ""

#: maxframe.tensor.random.standard_exponential.standard_exponential:1 of
msgid "Draw samples from the standard exponential distribution."
msgstr "从标准指数分布中抽取样本。"

#: maxframe.tensor.random.standard_exponential.standard_exponential:3 of
msgid ""
"`standard_exponential` is identical to the exponential distribution with "
"a scale parameter of 1."
msgstr "`standard_exponential` 与尺度参数为 1 的指数分布相同。"

#: maxframe.tensor.random.standard_exponential.standard_exponential of
msgid "参数"
msgstr ""

#: maxframe.tensor.random.standard_exponential.standard_exponential:6 of
msgid ""
"Output shape.  If the given shape is, e.g., ``(m, n, k)``, then ``m * n *"
" k`` samples are drawn.  Default is None, in which case a single value is"
" returned."
msgstr ""
"输出形状。如果给定的形状是，例如 ``(m, n, k)``，则抽取 ``m * n * k`` 个"
"样本。默认为 None，此时返回单个值。"

#: maxframe.tensor.random.standard_exponential.standard_exponential:10 of
msgid "Desired chunk size on each dimension"
msgstr "每个维度上的期望块大小"

#: maxframe.tensor.random.standard_exponential.standard_exponential:12 of
msgid "Allocate the tensor on GPU if True, False as default"
msgstr "如果为 True，则在 GPU 上分配张量，默认为 False"

#: maxframe.tensor.random.standard_exponential.standard_exponential:14 of
msgid "Data-type of the returned tensor."
msgstr "返回张量的数据类型。"

#: maxframe.tensor.random.standard_exponential.standard_exponential of
msgid "返回"
msgstr ""

#: maxframe.tensor.random.standard_exponential.standard_exponential:17 of
msgid "**out** -- Drawn samples."
msgstr "**out** -- 抽取的样本。"

#: maxframe.tensor.random.standard_exponential.standard_exponential of
msgid "返回类型"
msgstr ""

#: maxframe.tensor.random.standard_exponential.standard_exponential:21 of
msgid "示例"
msgstr ""

