msgid "maxframe.tensor.angle"
msgstr ""

#: maxframe.tensor.arithmetic.angle.angle:1 of
msgid "Return the angle of the complex argument."
msgstr "返回复数参数的角度。"

#: maxframe.tensor.arithmetic.angle.angle of
msgid "参数"
msgstr ""

#: maxframe.tensor.arithmetic.angle.angle:3 of
msgid "A complex number or sequence of complex numbers."
msgstr "一个复数或复数序列。"

#: maxframe.tensor.arithmetic.angle.angle:5 of
msgid "Return angle in degrees if True, radians if False (default)."
msgstr "如果为 True 则以度为单位返回角度，如果为 False（默认）则以弧度为单位。"

#: maxframe.tensor.arithmetic.angle.angle of
msgid "返回"
msgstr ""

#: maxframe.tensor.arithmetic.angle.angle:8 of
msgid ""
"**angle** -- The counterclockwise angle from the positive real axis on "
"the complex plane, with dtype as numpy.float64."
msgstr ""
"**angle** -- 复平面上从正实轴开始逆时针方向的角度，数据类型为 numpy."
"float64。"

#: maxframe.tensor.arithmetic.angle.angle of
msgid "返回类型"
msgstr ""

#: maxframe.tensor.arithmetic.angle.angle:12 of
msgid ":py:obj:`arctan2`, :py:obj:`absolute`"
msgstr ""

