msgid "返回类型"
msgstr ""

#: maxframe.learn.metrics._classification.accuracy_score:27 of
msgid ":py:obj:`jaccard_score`, :py:obj:`hamming_loss`, :py:obj:`zero_one_loss`"
msgstr ""

#: maxframe.learn.metrics._classification.accuracy_score:30 of
msgid "备注"
msgstr ""

#: maxframe.learn.metrics._classification.accuracy_score:31 of
msgid ""
"In binary and multiclass classification, this function is equal to the "
"``jaccard_score`` function."
msgstr "在二分类和多分类中，此函数等同于 ``jaccard_score`` 函数。"

