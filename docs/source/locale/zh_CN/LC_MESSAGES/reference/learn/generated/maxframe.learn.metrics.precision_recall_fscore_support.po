msgstr ""
"**recall** (*float (如果 average 不为 None) 或浮点数组，形状 =        [n_"
"unique_labels]*)"

#: maxframe.learn.metrics._classification.precision_recall_fscore_support:84 of
msgid ""
"**fbeta_score** (*float (if average is not None) or array of float, shape"
" =        [n_unique_labels]*)"
msgstr ""
"**fbeta_score** (*float (如果 average 不为 None) 或浮点数组，形状 =      "
"  [n_unique_labels]*)"

#: maxframe.learn.metrics._classification.precision_recall_fscore_support:85 of
msgid ""
"**support** (*None (if average is not None) or array of int, shape ="
"        [n_unique_labels]*) -- The number of occurrences of each label in"
" ``y_true``."
msgstr ""
"**support** (*None (如果 average 不为 None) 或整数数组，形状 =        [n_"
"unique_labels]*) —— ``y_true`` 中每个标签的出现次数。"

