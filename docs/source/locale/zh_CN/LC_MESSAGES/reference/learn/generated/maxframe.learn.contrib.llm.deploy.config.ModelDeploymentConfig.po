msgid "参数"
msgstr ""

#: maxframe.learn.contrib.llm.deploy.config.ModelDeploymentConfig:12 of
msgid "The name of the model."
msgstr "模型的名称。"

#: maxframe.learn.contrib.llm.deploy.config.ModelDeploymentConfig:14 of
msgid "The file path of the model."
msgstr "模型的文件路径。"

#: maxframe.learn.contrib.llm.deploy.config.ModelDeploymentConfig:16 of
msgid "The inference framework of the model."
msgstr "模型的推理框架。"

#: maxframe.learn.contrib.llm.deploy.config.ModelDeploymentConfig:18 of
msgid "The required resource files of the model."
msgstr "模型所需的资源文件。"

#: maxframe.learn.contrib.llm.deploy.config.ModelDeploymentConfig:20 of
msgid "The load params of the model."
msgstr "模型的加载参数。"

#: maxframe.learn.contrib.llm.deploy.config.ModelDeploymentConfig:22 of
msgid "The required cpu of the model."
msgstr "模型所需的 CPU 资源。"

#: maxframe.learn.contrib.llm.deploy.config.ModelDeploymentConfig:24 of
msgid "The required memory of the model."
msgstr "模型所需的内存资源。"

#: maxframe.learn.contrib.llm.deploy.config.ModelDeploymentConfig:26 of
msgid "The required gu of the model."
msgstr "模型所需的 GU 资源。"

#: maxframe.learn.contrib.llm.deploy.config.ModelDeploymentConfig:28 of
msgid "The required gpu memory of the model."
msgstr "模型所需的 GPU 显存。"

#: maxframe.learn.contrib.llm.deploy.config.ModelDeploymentConfig:30 of
msgid "The device of the model. One of \"cpu\" or \"cuda\"."
msgstr "模型所使用的设备，可选 \"cpu\" 或 \"cuda\"。"

#: maxframe.learn.contrib.llm.deploy.config.ModelDeploymentConfig:32 of
msgid "The properties of the model."
msgstr "模型的属性。"

#: maxframe.learn.contrib.llm.deploy.config.ModelDeploymentConfig:34 of
msgid "The tags of the model."
msgstr "模型的标签。"

